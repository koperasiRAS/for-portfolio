---
export interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="svc-card fade-up">
  <div class="svc-icon-wrap">
    <div class="svc-icon">
      <i class={icon}></i>
    </div>
  </div>
  <h3 class="svc-title">{title}</h3>
  <p class="svc-desc">{description}</p>
  <div class="svc-arrow">
    <i class="fas fa-arrow-right"></i>
  </div>
</div>
