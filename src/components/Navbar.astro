---
export interface Props {
  activePage?: string;
}

const { activePage = 'home' } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home', page: 'home' },
  { href: '/foto', label: 'Foto', page: 'foto' },
  { href: '/video', label: 'Video', page: 'video' },
  { href: '/design', label: 'Design', page: 'design' },
  { href: '/website', label: 'Website', page: 'website' },
  { href: '/editing', label: 'Editing', page: 'editing' },
];
---

<nav class="navbar" id="navbar" role="navigation" aria-label="Main navigation">
  <div class="logo">FOR</div>
  <ul class="nav-links" id="navLinks">
    {navLinks.map(link => (
      <li>
        <a
          href={link.href}
          class={activePage === link.page ? 'active' : ''}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
  <button type="button" class="theme-toggle" id="themeToggle" aria-label="Toggle theme" title="Ganti tema">
    <i class="fas fa-moon"></i>
  </button>
  <button type="button" class="nav-toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<script>
  const navToggle = document.getElementById('navToggle');
  const navLinks = document.getElementById('navLinks');

  if (navToggle && navLinks) {
    // Toggle hamburger ↔ X
    navToggle.addEventListener('click', () => {
      const isOpen = navLinks.classList.toggle('open');
      navToggle.classList.toggle('active', isOpen);
      navToggle.setAttribute('aria-expanded', String(isOpen));
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });

    // Close on link click
    navLinks.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        navLinks.classList.remove('open');
        navToggle.classList.remove('active');
        navToggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      });
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      const navbar = document.getElementById('navbar');
      if (!navbar.contains(e.target)) {
        navLinks.classList.remove('open');
        navToggle.classList.remove('active');
        navToggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
    });
  }

  // Theme toggle
  const themeToggle = document.getElementById('themeToggle');
  function applyTheme(isLight) {
    const icon = themeToggle ? themeToggle.querySelector('i') : null;
    if (isLight) {
      document.documentElement.setAttribute('data-theme', 'light');
      localStorage.setItem('for-theme', 'light');
      if (icon) { icon.classList.remove('fa-moon'); icon.classList.add('fa-sun'); }
    } else {
      document.documentElement.removeAttribute('data-theme');
      localStorage.setItem('for-theme', 'dark');
      if (icon) { icon.classList.remove('fa-sun'); icon.classList.add('fa-moon'); }
    }
  }
  // Sync icon with current saved theme on load
  (function syncIcon() {
    const saved = localStorage.getItem('for-theme');
    if (saved === 'light' && themeToggle) {
      const icon = themeToggle.querySelector('i');
      if (icon) { icon.classList.remove('fa-moon'); icon.classList.add('fa-sun'); }
    }
  })();
  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const isLight = document.documentElement.getAttribute('data-theme') !== 'light';
      applyTheme(isLight);
    });
  }
</script>

