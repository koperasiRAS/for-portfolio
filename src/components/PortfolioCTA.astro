---
// Consistent CTA section used across all portfolio pages
import { waLink } from '../utils/whatsapp.js';
---

<section class="portfolio-cta">
  <div class="portfolio-cta-inner fade-up">
    <h2>Suka dengan karya ini?</h2>
    <p>Mari berkolaborasi. Setiap project dimulai dari satu percakapan.</p>
    <a href={waLink('collab')} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
      <i class="fab fa-whatsapp"></i> Hubungi via WhatsApp
    </a>
  </div>
</section>
