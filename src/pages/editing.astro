---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PortfolioCTA from '../components/PortfolioCTA.astro';
---

<BaseLayout
  title="Video Editing | Frame Of Rangga"
  description="Jasa video editing profesional — cinematic film, brand campaign, konten kreator, dan wedding video oleh Rangga Danuarta."
  keywords="video editing, color grading, motion graphics, retouching, Adobe Premiere Pro, After Effects, cinematic editing, wedding video"
  ogTitle="Video Editing | Frame Of Rangga"
  ogDescription="Jasa video editing profesional — cinematic film, brand campaign, konten kreator, dan wedding video oleh Rangga Danuarta."
  ogUrl="https://web-portfolio-gray-ten.vercel.app/editing"
  hasGlightbox={true}
>
  <Navbar slot="navbar" activePage="editing" />

  <section class="gallery-section" transition:animate="fade">
    <h1 class="fade-up">Video Editing</h1>
    <p class="gallery-subtitle fade-up">Hasil kerja video dan foto — mulai dari color grading, retouch, sampai motion graphics.</p>

    <!-- Filter Bar -->
    <div class="filter-bar fade-up" aria-label="Filter by editing style">
      <button class="filter-btn active" data-filter="all">Semua</button>
      <button class="filter-btn" data-filter="colorgrading">Color Grading</button>
      <button class="filter-btn" data-filter="retouch">Retouch Foto</button>
      <button class="filter-btn" data-filter="videoedit">Video Editing</button>
      <button class="filter-btn" data-filter="motion">Motion Graphics</button>
    </div>

    <!-- Editing Gallery Grid -->
    <div class="gallery-grid fade-up">

      <!-- Video Editing -->
      <a class="gallery-item glightbox"
         href="/assets/thumbnails/ss keyboard.png"
         data-gallery="editing-gallery"
         data-title="Video Editing — WIP Recap"
         data-category="videoedit">
        <img src="/assets/thumbnails/ss keyboard.png" alt="WIP Recap" loading="lazy" width="600" height="400" onerror="this.style.display='none'" />
        <div class="gallery-overlay">
          <span class="video-cat-badge">Video Editing</span>
          <span class="gallery-item-title">Waktu Indonesia Padel Recap</span>
          <i class="fas fa-expand"></i>
        </div>
      </a>

      <a class="gallery-item glightbox"
         href="/assets/thumbnails/ss laptop.png"
         data-gallery="editing-gallery"
         data-title="Video Editing — Creative Content"
         data-category="videoedit">
        <img src="/assets/thumbnails/ss laptop.png" alt="Creative Video" loading="lazy" width="600" height="400" onerror="this.style.display='none'" />
        <div class="gallery-overlay">
          <span class="video-cat-badge">Video Editing</span>
          <span class="gallery-item-title">Creative Video Edit</span>
          <i class="fas fa-expand"></i>
        </div>
      </a>

      <!-- Color Grading — using web screenshot as before/after preview -->
      <a class="gallery-item glightbox"
         href="/assets/thumbnails/web1.png"
         data-gallery="editing-gallery"
         data-title="Color Grading — Brand Assets"
         data-category="colorgrading">
        <img src="/assets/thumbnails/web1.png" alt="Color Grading Preview" loading="lazy" width="600" height="400" onerror="this.style.display='none'" />
        <div class="gallery-overlay">
          <span class="video-cat-badge">Color Grading</span>
          <span class="gallery-item-title">Color Grading Preview</span>
          <i class="fas fa-expand"></i>
        </div>
      </a>

      <!-- Retouch Foto -->
      <a class="gallery-item glightbox"
         href="/assets/foto/fotografer/fotografi mobil.jpg"
         data-gallery="editing-gallery"
         data-title="Retouch — Fotografi Mobil"
         data-category="retouch">
        <img src="/assets/foto/fotografer/fotografi mobil.jpg" alt="Retouch Fotografi Mobil" loading="lazy" width="600" height="400" onerror="this.style.display='none'" />
        <div class="gallery-overlay">
          <span class="video-cat-badge">Retouch Foto</span>
          <span class="gallery-item-title">Fotografi Mobil</span>
          <i class="fas fa-expand"></i>
        </div>
      </a>

      <a class="gallery-item glightbox"
         href="/assets/foto/fotografer/ccm rangga.jpg"
         data-gallery="editing-gallery"
         data-title="Retouch — CCM Lifestyle"
         data-category="retouch">
        <img src="/assets/foto/fotografer/ccm rangga.jpg" alt="CCM Lifestyle" loading="lazy" width="600" height="400" onerror="this.style.display='none'" />
        <div class="gallery-overlay">
          <span class="video-cat-badge">Retouch Foto</span>
          <span class="gallery-item-title">CCM Lifestyle</span>
          <i class="fas fa-expand"></i>
        </div>
      </a>

      <a class="gallery-item glightbox"
         href="/assets/foto/fotografer/fotografi gojek.jpg"
         data-gallery="editing-gallery"
         data-title="Retouch — Gojek Brand Photography"
         data-category="retouch">
        <img src="/assets/foto/fotografer/fotografi gojek.jpg" alt="Gojek Brand Photography" loading="lazy" width="600" height="400" onerror="this.style.display='none'" />
        <div class="gallery-overlay">
          <span class="video-cat-badge">Retouch Foto</span>
          <span class="gallery-item-title">Gojek Brand Photography</span>
          <i class="fas fa-expand"></i>
        </div>
      </a>

      <!-- Motion Graphics — using poster design as motion-ready asset -->
      <a class="gallery-item glightbox"
         href="/assets/design/social/poster edukasi.png"
         data-gallery="editing-gallery"
         data-title="Motion Graphics — Poster Edukasi"
         data-category="motion">
        <img src="/assets/design/social/poster edukasi.png" alt="Motion Graphics Poster" loading="lazy" width="600" height="400" onerror="this.style.display='none'" />
        <div class="gallery-overlay">
          <span class="video-cat-badge">Motion Graphics</span>
          <span class="gallery-item-title">Poster Edukasi — Motion-Ready</span>
          <i class="fas fa-expand"></i>
        </div>
      </a>

      <a class="gallery-item glightbox"
         href="/assets/design/social/poster product.png"
         data-gallery="editing-gallery"
         data-title="Motion Graphics — Poster Product"
         data-category="motion">
        <img src="/assets/design/social/poster product.png" alt="Motion Graphics Product" loading="lazy" width="600" height="400" onerror="this.style.display='none'" />
        <div class="gallery-overlay">
          <span class="video-cat-badge">Motion Graphics</span>
          <span class="gallery-item-title">Poster Product — Motion-Ready</span>
          <i class="fas fa-expand"></i>
        </div>
      </a>

    </div>

    <!-- Editing Styles Info Cards -->
    <div class="editing-grid fade-up" style="margin-top: 48px;">
      <div class="editing-card">
        <div class="editing-icon"><i class="fas fa-film"></i></div>
        <h3>Cinematic Edit</h3>
        <p>Color grading sinematik, pacing yang terasa, dan storytelling visual yang kuat — cocok untuk short film dan brand film.</p>
      </div>
      <div class="editing-card">
        <div class="editing-icon"><i class="fas fa-bullhorn"></i></div>
        <h3>Brand Campaign</h3>
        <p>Video promosi yang on-brand, engaging, dan langsung nge-hit target audiens. Dari script sampai final cut.</p>
      </div>
      <div class="editing-card">
        <div class="editing-icon"><i class="fas fa-heart"></i></div>
        <h3>Wedding Video</h3>
        <p>Momen-momen precious yang diabadikan dengan editing yang rapi, emosional, dan estetik.</p>
      </div>
      <div class="editing-card">
        <div class="editing-icon"><i class="fas fa-mobile-alt"></i></div>
        <h3>Konten Kreator</h3>
        <p>Editing kilat, trend-aware, dan platform-optimized untuk TikTok, Reels, dan YouTube Shorts.</p>
      </div>
      <div class="editing-card">
        <div class="editing-icon"><i class="fas fa-tv"></i></div>
        <h3>Recap &amp; Aftermovie</h3>
        <p>Rangkuman event atau acara dalam format video yang dinamis dan memorable.</p>
      </div>
      <div class="editing-card">
        <div class="editing-icon"><i class="fas fa-magic"></i></div>
        <h3>Motion Graphics</h3>
        <p>Lower thirds, intro/outro, dan elemen motion graphic untuk naikin production value video.</p>
      </div>
    </div>

    <div style="display:flex;gap:16px;flex-wrap:wrap;justify-content:center;margin-top:40px;">
      <a href="/video" class="btn btn-primary fade-up">
        <i class="fas fa-play"></i> Lihat Video Portfolio
      </a>
      <a href="https://wa.me/62895321693131" target="_blank" rel="noopener noreferrer" class="btn btn-ghost fade-up">
        <i class="fab fa-whatsapp"></i> Konsultasi Project
      </a>
    </div>
  </section>

  <!-- CTA -->
  <PortfolioCTA />

  <Footer slot="footer" variant="minimal" />
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', function initGL() {
    if (typeof GLightbox === 'undefined') {
      setTimeout(initGL, 100);
      return;
    }
    GLightbox({
      selector: '.glightbox',
      touchNavigation: true,
      loop: true,
      autoplayVideos: false,
      zoomable: true,
    });
  });
</script>
