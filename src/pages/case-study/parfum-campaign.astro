---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PortfolioCTA from '../../components/PortfolioCTA.astro';
---

<BaseLayout
  title="Brand Design Case Study Parfum Campaign | Frame Of Rangga"
  description="Case study desain brand advertising parfum dari conceptualization hingga final delivery. Visual campaign yang luxury, cinematic, dan memorable."
  ogImage="https://for-portfolio-mu.vercel.app/assets/og/og-design.jpg"
  ogUrl="https://for-portfolio-mu.vercel.app/case-study/parfum-campaign"
>
  <Navbar slot="navbar" activePage="design" />

  <!-- CASE STUDY HERO -->
  <section class="cs-hero" transition:animate="fade">
    <div class="cs-hero-glow" aria-hidden="true"></div>
    <div class="cs-hero-inner">
      <div class="cs-hero-meta">
        <span class="cs-category-badge">Brand Design</span>
        <span class="cs-year">2024</span>
      </div>
      <h1 class="cs-hero-title">Parfum<br /><span class="cs-hero-accent">Advertising Campaign</span></h1>
      <p class="cs-hero-sub">
        Menciptakan visual campaign untuk produk parfum luxury dengan pendekatan cinematic editorial photography menggabungkan luxury aesthetics dengan storytelling yang emosional dan memorable.
      </p>
      <div class="cs-hero-stats">
        <div class="cs-stat">
          <span class="cs-stat-num">5+</span>
          <span class="cs-stat-label">Creative Assets</span>
        </div>
        <div class="cs-stat">
          <span class="cs-stat-num">2</span>
          <span class="cs-stat-label">Brand Guidelines</span>
        </div>
        <div class="cs-stat">
          <span class="cs-stat-num">3</span>
          <span class="cs-stat-label">Social Platforms</span>
        </div>
        <div class="cs-stat">
          <span class="cs-stat-num">1</span>
          <span class="cs-stat-label">Art Direction</span>
        </div>
      </div>
    </div>
    <div class="cs-hero-image">
      <img
        src="/assets/design/social/desain iklan parfum.png"
        alt="Parfum Advertising Campaign Brand Design Case Study"
        loading="eager"
        fetchpriority="high"
      />
      <div class="cs-hero-image-overlay"></div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- OVERVIEW -->
  <section class="cs-section" transition:animate="fade">
    <div class="cs-inner">
      <div class="cs-overview-grid">
        <div class="cs-overview-left fade-up">
          <span class="cs-section-label gradient-label">OVERVIEW</span>
          <h2 class="cs-section-title">The Challenge</h2>
          <p>
            Klien memiliki produk parfum luxury yang ingin diposisikan di pasar premium Indonesia. Tantangan utama: mengkomunikasikan luxury, eksklusivitas, dan emosional appeal dari sebuah fragrance dalam medium visual statis.
          </p>
          <p>
            Parfum adalah produk yang unik konsumen membeli "impulse of a feeling", bukan sekadar physical product. Tugas desainer adalah menjembatani gap antara abstract scent dan visual representation yang bisa membangkitkan emosi dan desire.
          </p>
          <p>
            Brief tambahan: campaign harus versatile untuk multiple platforms (Instagram feed, story, carousel, print collateral) dengan satu cohesive visual language yang tetap powerful di setiap format.
          </p>
        </div>
        <div class="cs-overview-right fade-up">
          <div class="cs-info-card">
            <div class="cs-info-row">
              <span class="cs-info-label">Client</span>
              <span class="cs-info-value">Luxury Fragrance Brand</span>
            </div>
            <div class="cs-info-row">
              <span class="cs-info-label">Kategori</span>
              <span class="cs-info-value">Advertising / Brand Design</span>
            </div>
            <div class="cs-info-row">
              <span class="cs-info-label">Deliverables</span>
              <span class="cs-info-value">Social Media, Print, OOH</span>
            </div>
            <div class="cs-info-row">
              <span class="cs-info-label">Tools</span>
              <span class="cs-info-value">Photoshop, Illustrator</span>
            </div>
            <div class="cs-info-row">
              <span class="cs-info-label">Style</span>
              <span class="cs-info-value">Cinematic Editorial</span>
            </div>
            <div class="cs-info-row">
              <span class="cs-info-label">Timeline</span>
              <span class="cs-info-value">2 Minggu</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- BRAND STRATEGY -->
  <section class="cs-section" transition:animate="fade">
    <div class="cs-inner">
      <div class="fade-up">
        <span class="cs-section-label gradient-label">STRATEGY</span>
        <h2 class="cs-section-title">Art Direction Framework</h2>
      </div>
      <div class="cs-strategy-grid fade-up">

        <div class="cs-strategy-card">
          <div class="cs-strategy-mood">MOODBOARD</div>
          <div class="cs-strategy-tags">
            <span class="cs-tag">Midnight Luxe</span>
            <span class="cs-tag">Velvet Dark</span>
            <span class="cs-tag">Golden Hour</span>
            <span class="cs-tag">Editorial Noir</span>
          </div>
          <p class="cs-strategy-quote">
            "Scent of the night where luxury meets mystery, and every bottle tells a story of the extraordinary."
          </p>
        </div>

        <div class="cs-strategy-card">
          <div class="cs-strategy-mood">COLOR PALETTE</div>
          <div class="cs-color-row">
            <div class="cs-color-swatch" style="background: #0a0614;"></div>
            <div class="cs-color-swatch" style="background: #1a0a2e;"></div>
            <div class="cs-color-swatch" style="background: #c9a84c;"></div>
            <div class="cs-color-swatch" style="background: #f5e6c8;"></div>
            <div class="cs-color-swatch" style="background: #2a1a3e;"></div>
          </div>
          <p class="cs-strategy-desc">
            Deep purples dan midnight blacks sebagai base gold accents untuk luxury feel, cream whites untuk elegance. Warna-warna ini berkomunikasi: premium, mysterious, sophisticated.
          </p>
        </div>

        <div class="cs-strategy-card">
          <div class="cs-strategy-mood">TYPOGRAPHY</div>
          <div class="cs-typo-row">
            <span style="font-family: 'Manrope'; font-weight: 800; font-size: 22px; color: #fff; letter-spacing: -0.5px;">MANROPE</span>
            <span style="font-size: 11px; color: var(--on-surface-variant);">Headlines</span>
          </div>
          <div class="cs-typo-row">
            <span style="font-family: 'Inter'; font-size: 16px; color: rgba(255,255,255,0.7);">Inter Regular</span>
            <span style="font-size: 11px; color: var(--on-surface-variant);">Body Copy</span>
          </div>
          <p class="cs-strategy-desc">
            Clean, modern typography yang tidak competes dengan visual. Headlines bold dan impactful, body text readable dan refined. Contrast yang tepat antara display dan text type.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- ASSET SHOWCASE -->
  <section class="cs-section cs-gallery-section" transition:animate="fade">
    <div class="cs-inner">
      <div class="cs-gallery-header fade-up">
        <span class="cs-section-label gradient-label">FINAL CREATIVE ASSETS</span>
        <h2 class="cs-section-title">The Deliverables</h2>
      </div>
      <div class="cs-assets-grid fade-up">
        <div class="cs-asset cs-asset-featured">
          <img
            src="/assets/design/social/desain iklan parfum.png"
            alt="Parfum Campaign Main Visual"
            loading="lazy"
          />
          <div class="cs-asset-label">
            <span class="cs-asset-cat">Hero Visual</span>
            <p>Main campaign Instagram Feed</p>
          </div>
        </div>
        <div class="cs-asset">
          <img
            src="/assets/design/social/carousels 1.png"
            alt="Parfum Campaign Carousel"
            loading="lazy"
          />
          <div class="cs-asset-label">
            <span class="cs-asset-cat">Carousel</span>
            <p>Storytelling sequence 5 slides</p>
          </div>
        </div>
        <div class="cs-asset">
          <img
            src="/assets/design/brand/skincare.png"
            alt="Brand Identity Packaging Design"
            loading="lazy"
          />
          <div class="cs-asset-label">
            <span class="cs-asset-cat">Brand Extension</span>
            <p>Cross-category brand extension</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- CREATIVE PROCESS -->
  <section class="cs-section" transition:animate="fade">
    <div class="cs-inner">
      <div class="fade-up">
        <span class="cs-section-label gradient-label">PROCESS</span>
        <h2 class="cs-section-title">How the Magic Happened</h2>
      </div>
      <div class="cs-process-timeline fade-up">
        <div class="cs-timeline-item">
          <div class="cs-timeline-dot"></div>
          <div class="cs-timeline-content">
            <div class="cs-timeline-meta">
              <span class="cs-timeline-step">Week 1 Day 1-2</span>
            </div>
            <h3>Discovery &amp; Research</h3>
            <p>
              Mendalami brief, riset kompetitor (luxury perfume brands globally), dan referensi visual. Menganalisis apa yang membuat campaign parfum berhasil emotional storytelling, sensory cues, dan visual metaphors yang universal.
            </p>
          </div>
        </div>
        <div class="cs-timeline-item">
          <div class="cs-timeline-dot"></div>
          <div class="cs-timeline-content">
            <div class="cs-timeline-meta">
              <span class="cs-timeline-step">Week 1 Day 3-4</span>
            </div>
            <h3>Moodboard &amp; Concept</h3>
            <p>
              Membuat 3 moodboard concepts dan memilih 1 arah kreatif yang paling aligned dengan brand positioning. Direction: "Midnight Luxe" visual yang menangkap essence of the night, mystery, dan sophistication.
            </p>
          </div>
        </div>
        <div class="cs-timeline-item">
          <div class="cs-timeline-dot"></div>
          <div class="cs-timeline-content">
            <div class="cs-timeline-meta">
              <span class="cs-timeline-step">Week 1 Day 5</span>
            </div>
            <h3>Art Direction</h3>
            <p>
              Menentukan composition principles, lighting direction, color grading approach, dan typography hierarchy. Membuat production brief untuk mockup photography atau stock photo selection.
            </p>
          </div>
        </div>
        <div class="cs-timeline-item">
          <div class="cs-timeline-dot"></div>
          <div class="cs-timeline-content">
            <div class="cs-timeline-meta">
              <span class="cs-timeline-step">Week 2 Day 1-3</span>
            </div>
            <h3>Design Execution</h3>
            <p>
              Mockup creation, compositing, color grading, dan typography integration. Setiap asset dibuat dengan consistency dalam mind sehingga semua output terasa seperti bagian dari satu cohesive campaign.
            </p>
          </div>
        </div>
        <div class="cs-timeline-item">
          <div class="cs-timeline-dot"></div>
          <div class="cs-timeline-content">
            <div class="cs-timeline-meta">
              <span class="cs-timeline-step">Week 2 Day 4-5</span>
            </div>
            <h3>Review &amp; Refinement</h3>
            <p>
              Client review, revisions berdasarkan feedback, dan final delivery. Semua assets di-deliver dalam format yang optimized untuk masing-masing platform dari Instagram square (1080x1080) hingga story (1080x1920).
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- PLATFORM VERSATILITY -->
  <section class="cs-section" transition:animate="fade">
    <div class="cs-inner">
      <div class="fade-up">
        <span class="cs-section-label gradient-label">ADAPTABILITY</span>
        <h2 class="cs-section-title">Multi-Platform Execution</h2>
        <p class="cs-platforms-desc">
          Satu arah kreatif, diadaptasi untuk berbagai format dan platform tanpa losing the essence of the campaign.
        </p>
      </div>
      <div class="cs-platforms-grid fade-up">
        <div class="cs-platform-card">
          <div class="cs-platform-icon"><i class="fab fa-instagram"></i></div>
          <h3>Instagram Feed</h3>
          <p>1080×1080px square format hero visuals dan key campaign imagery yang berfungsi sebagai visual anchor untuk seluruh feed.</p>
          <span class="cs-platform-format">Square 1:1</span>
        </div>
        <div class="cs-platform-card">
          <div class="cs-platform-icon"><i class="fas fa-mobile-alt"></i></div>
          <h3>Instagram Stories</h3>
          <p>1080×1920px vertical format untuk behind-the-scenes, countdown, atau teaser content yang driving engagement.</p>
          <span class="cs-platform-format">Portrait 9:16</span>
        </div>
        <div class="cs-platform-card">
          <div class="cs-platform-icon"><i class="fas fa-play-circle"></i></div>
          <h3>Instagram Carousel</h3>
          <p>1080×1080px per slide, 5-7 slides storytelling sequence yang educate, inspire, dan convert followers jadi buyers.</p>
          <span class="cs-platform-format">Carousel 1:1</span>
        </div>
        <div class="cs-platform-card">
          <div class="cs-platform-icon"><i class="fas fa-print"></i></div>
          <h3>Print Collateral</h3>
          <p>High-resolution untuk printed materials hang tags, box packaging, dan POP materials yang maintain luxury feel di physical space.</p>
          <span class="cs-platform-format">CMYK 300dpi</span>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- KEY PRINCIPLES -->
  <section class="cs-section" transition:animate="fade">
    <div class="cs-inner">
      <div class="fade-up">
        <span class="cs-section-label gradient-label">LESSONS LEARNED</span>
        <h2 class="cs-section-title">Principles in Action</h2>
      </div>
      <div class="cs-principles-grid fade-up">
        <div class="cs-principle">
          <div class="cs-principle-icon"><i class="fas fa-eye"></i></div>
          <div>
            <h3>Emotional First, Technical Second</h3>
            <p>
              Dalam advertising parfum, logical selling points (notes, longevity, sillage) itu second. Yang first adalah emotional connection apakah visual ini membuat orang FEEL something? Itu yang akan drive purchase decision.
            </p>
          </div>
        </div>
        <div class="cs-principle">
          <div class="cs-principle-icon"><i class="fas fa-gem"></i></div>
          <div>
            <h3>Less is More in Luxury</h3>
            <p>
              Luxury tidak communicated lewat complexity atau busyness. Justru sebaliknya simplicity, whitespace, dan restraint dalam visual communication communicate exclusivity dengan lebih kuat. Setiap element harus earn its place.
            </p>
          </div>
        </div>
        <div class="cs-principle">
          <div class="cs-principle-icon"><i class="fas fa-infinity"></i></div>
          <div>
            <h3>Cohesion Over Cleverness</h3>
            <p>
              Satu visual language yang consistently applied > 10 creative executions yang brilliant tapi inconsistent. Cohesive brand presence build trust dan recognition dan itu jauh lebih valuable daripada being clever once.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- NEXT PROJECT CTA -->
  <PortfolioCTA />

  <!-- Footer -->
  <Footer slot="footer" variant="minimal" />
</BaseLayout>

<style>
  /* ===== HERO ===== */
  .cs-hero {
    position: relative;
    padding: 120px 64px 0;
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .cs-hero-glow {
    position: absolute;
    top: -10%;
    right: -5%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(193, 128, 255, 0.1) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
  }

  .cs-hero-inner {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .cs-hero-meta {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .cs-category-badge {
    display: inline-flex;
    padding: 5px 14px;
    border-radius: 9999px;
    background: rgba(163, 166, 255, 0.12);
    border: 1px solid rgba(163, 166, 255, 0.2);
    color: var(--accent-primary);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .cs-year {
    font-size: 13px;
    color: var(--on-surface-variant);
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
  }

  .cs-hero-title {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(36px, 4vw, 60px);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -1.5px;
    color: var(--on-surface);
  }

  .cs-hero-accent {
    color: var(--accent-secondary);
  }

  .cs-hero-sub {
    font-size: 15px;
    line-height: 1.8;
    color: var(--on-surface-variant);
    max-width: 480px;
  }

  .cs-hero-stats {
    display: flex;
    gap: 24px;
    margin-top: 12px;
    flex-wrap: wrap;
  }

  .cs-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cs-stat-num {
    font-family: 'Manrope', sans-serif;
    font-size: 24px;
    font-weight: 800;
    color: var(--accent-secondary);
    letter-spacing: -0.5px;
    line-height: 1;
  }

  .cs-stat-label {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--on-surface-variant);
  }

  .cs-hero-image {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(163, 166, 255, 0.08);
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.5);
  }

  .cs-hero-image img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  .cs-hero-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10, 6, 20, 0.5), transparent 60%);
  }

  /* ===== SECTIONS ===== */
  .cs-section {
    padding: 80px 0;
  }

  .cs-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 64px;
  }

  .cs-section-label {
    display: inline-block;
    font-family: 'Manrope', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-primary);
    margin-bottom: 12px;
  }

  .gradient-label {
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cs-section-title {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 800;
    color: var(--on-surface);
    letter-spacing: -0.5px;
    line-height: 1.15;
    margin-bottom: 32px;
  }

  .section-divider {
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(163, 166, 255, 0.12) 20%,
      rgba(193, 128, 255, 0.12) 80%,
      transparent
    );
    margin: 0 64px;
  }

  /* ===== OVERVIEW ===== */
  .cs-overview-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 80px;
    align-items: start;
  }

  .cs-overview-left p {
    font-size: 15px;
    line-height: 1.85;
    color: var(--on-surface-variant);
    margin-bottom: 16px;
  }

  .cs-info-card {
    background: var(--surface-container);
    border: 1px solid rgba(163, 166, 255, 0.08);
    border-radius: 20px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cs-info-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 14px 0;
    border-bottom: 1px solid rgba(163, 166, 255, 0.06);
    gap: 16px;
  }

  .cs-info-row:last-child {
    border-bottom: none;
  }

  .cs-info-label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--on-surface-variant);
    flex-shrink: 0;
  }

  .cs-info-value {
    font-size: 13px;
    color: var(--on-surface);
    text-align: right;
    font-family: 'Inter', sans-serif;
  }

  /* ===== STRATEGY ===== */
  .cs-strategy-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .cs-strategy-card {
    background: var(--surface-container);
    border: 1px solid rgba(163, 166, 255, 0.08);
    border-radius: 20px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .cs-strategy-card:hover {
    transform: translateY(-4px);
    border-color: rgba(163, 166, 255, 0.18);
  }

  .cs-strategy-mood {
    font-family: 'Manrope', sans-serif;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-secondary);
  }

  .cs-strategy-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .cs-tag {
    padding: 5px 12px;
    border-radius: 9999px;
    background: rgba(193, 128, 255, 0.1);
    border: 1px solid rgba(193, 128, 255, 0.2);
    color: var(--accent-secondary);
    font-size: 11px;
    font-weight: 600;
  }

  .cs-strategy-quote {
    font-size: 13px;
    font-style: italic;
    line-height: 1.7;
    color: var(--on-surface);
    border-left: 2px solid var(--accent-secondary);
    padding-left: 14px;
  }

  .cs-color-row {
    display: flex;
    gap: 8px;
  }

  .cs-color-swatch {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: transform 0.2s ease;
    cursor: default;
  }

  .cs-color-swatch:hover {
    transform: scale(1.1);
  }

  .cs-typo-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cs-strategy-desc {
    font-size: 13px;
    line-height: 1.7;
    color: var(--on-surface-variant);
  }

  /* ===== ASSETS GALLERY ===== */
  .cs-gallery-section {
    background: var(--surface-container);
  }

  .cs-gallery-header {
