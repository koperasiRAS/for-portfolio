---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PortfolioCTA from '../../components/PortfolioCTA.astro';
---

<BaseLayout
  title="Web Development Case Study FOR Portfolio | Frame Of Rangga"
  description="Case study pembuatan FOR Portfolio Website dari conceptualization hingga deployment. Tech stack Astro, design system glassmorphism, dan deployment Vercel."
  ogImage="https://for-portfolio-mu.vercel.app/assets/og/og-website.jpg"
  ogUrl="https://for-portfolio-mu.vercel.app/case-study/for-portfolio"
>
  <Navbar slot="navbar" activePage="website" />

  <!-- CASE STUDY HERO -->
  <section class="cs-hero" transition:animate="fade">
    <div class="cs-hero-glow" aria-hidden="true"></div>
    <div class="cs-hero-inner">
      <div class="cs-hero-meta">
        <span class="cs-category-badge">Web Development</span>
        <span class="cs-year">2024</span>
      </div>
      <h1 class="cs-hero-title">FOR Portfolio<br /><span class="cs-hero-accent">Website</span></h1>
      <p class="cs-hero-sub">
        Membangun portfolio website yang mencerminkan identitas Visual Storyteller dengan aesthetic dark glassmorphism, performa tinggi, dan pengalaman pengguna yang seamless di semua device.
      </p>
      <div class="cs-hero-stats">
        <div class="cs-stat">
          <span class="cs-stat-num">6</span>
          <span class="cs-stat-label">Pages</span>
        </div>
        <div class="cs-stat">
          <span class="cs-stat-num">100</span>
          <span class="cs-stat-label">Lighthouse Score</span>
        </div>
        <div class="cs-stat">
          <span class="cs-stat-num">1.8s</span>
          <span class="cs-stat-label">Load Time (LCP)</span>
        </div>
        <div class="cs-stat">
          <span class="cs-stat-num">0</span>
          <span class="cs-stat-label">External CMS</span>
        </div>
      </div>
    </div>
    <div class="cs-hero-image">
      <img
        src="/assets/thumbnails/web1.png"
        alt="FOR Portfolio Website Web Development Case Study"
        loading="eager"
        fetchpriority="high"
      />
      <div class="cs-hero-image-overlay"></div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- OVERVIEW -->
  <section class="cs-section" transition:animate="fade">
    <div class="cs-inner">
      <div class="cs-overview-grid">
        <div class="cs-overview-left fade-up">
          <span class="cs-section-label gradient-label">OVERVIEW</span>
          <h2 class="cs-section-title">The Brief</h2>
          <p>
            FRAME OF RANGA (FOR) membutuhkan portfolio website yang bisa menampilkan empat layanan utama Photography, Videography, Brand Design, dan Web Development dalam satu platform yang kohesif dan berkesan.
          </p>
          <p>
            Tantangan utama: bagaimana membuat website yang mencerminkan creative vision seorang Visual Storyteller, sambil tetap fast-loading, SEO-friendly, dan easy to maintain tanpa compromet aesthetic quality.
          </p>
          <p>
            Solution: Static site generation dengan Astro, custom CSS design system, dan deployment Vercel untuk performa maximum.
          </p>
        </div>
        <div class="cs-overview-right fade-up">
          <div class="cs-info-card">
            <div class="cs-info-row">
              <span class="cs-info-label">Client</span>
              <span class="cs-info-value">Rangga Danuarta / FOR</span>
            </div>
            <div class="cs-info-row">
              <span class="cs-info-label">Kategori</span>
              <span class="cs-info-value">Web Development</span>
            </div>
            <div class="cs-info-row">
              <span class="cs-info-label">Tech Stack</span>
              <span class="cs-info-value">Astro v6, CSS Variables, JS</span>
            </div>
            <div class="cs-info-row">
              <span class="cs-info-label">Hosting</span>
              <span class="cs-info-value">Vercel (CDN)</span>
            </div>
            <div class="cs-info-row">
              <span class="cs-info-label">Timeline</span>
              <span class="cs-info-value">3 Minggu</span>
            </div>
            <div class="cs-info-row">
              <span class="cs-info-label">URL</span>
              <span class="cs-info-value">
                <a href="https://for-portfolio-mu.vercel.app" target="_blank" rel="noopener" style="color: var(--accent-primary); text-decoration: none;">
                  for-portfolio-mu.vercel.app ↗
                </a>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- DESIGN SYSTEM -->
  <section class="cs-section" transition:animate="fade">
    <div class="cs-inner">
      <div class="fade-up">
        <span class="cs-section-label gradient-label">DESIGN SYSTEM</span>
        <h2 class="cs-section-title">Stitch Glassmorphism Dark Theme</h2>
      </div>
      <div class="cs-design-grid fade-up">
        <div class="cs-design-block">
          <div class="cs-design-label">Background Surface</div>
          <div class="cs-design-swatches">
            <div class="cs-swatch" style="background: #060e20;" title="#060e20"></div>
            <div class="cs-swatch" style="background: #0c1528;" title="#0c1528"></div>
            <div class="cs-swatch" style="background: #111e38;" title="#111e38"></div>
          </div>
        </div>
        <div class="cs-design-block">
          <div class="cs-design-label">Accent Colors</div>
          <div class="cs-design-swatches">
            <div class="cs-swatch" style="background: #a3a6ff;" title="#a3a6ff (Primary)"></div>
            <div class="cs-swatch" style="background: #c180ff;" title="#c180ff (Secondary)"></div>
            <div class="cs-swatch" style="background: #8ab0ff;" title="#8ab0ff (Tertiary)"></div>
          </div>
        </div>
        <div class="cs-design-block">
          <div class="cs-design-label">Typography</div>
          <div class="cs-design-typo">
            <span style="font-family: 'Manrope'; font-weight: 800; font-size: 28px; color: var(--on-surface);">Manrope</span>
            <span style="font-size: 12px; color: var(--on-surface-variant);">Headings 200/400/600/700/800</span>
          </div>
          <div class="cs-design-typo">
            <span style="font-family: 'Inter'; font-size: 18px; color: var(--on-surface);">Inter</span>
            <span style="font-size: 12px; color: var(--on-surface-variant);">Body 300/400/500/600</span>
          </div>
        </div>
        <div class="cs-design-block cs-design-block-wide">
          <div class="cs-design-label">Design Tokens (CSS Variables)</div>
          <div class="cs-design-code">
            <pre>--accent-primary: #a3a6ff;
--accent-secondary: #c180ff;
--surface-container: #060e20;
--surface-container-high: #0c1528;
--surface-container-highest: #111e38;
--radius-sm: 8px;
--radius-md: 16px;
--radius-lg: 24px;</pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- TECH STACK -->
  <section class="cs-section" transition:animate="fade">
    <div class="cs-inner">
      <div class="cs-tech-header fade-up">
        <span class="cs-section-label gradient-label">TECHNICAL</span>
        <h2 class="cs-section-title">Why Astro?</h2>
      </div>
      <div class="cs-tech-grid fade-up">

        <div class="cs-tech-card">
          <div class="cs-tech-icon"><i class="fas fa-bolt"></i></div>
          <h3>Zero JavaScript by Default</h3>
          <p>
            Astro mengirim nol JavaScript ke client secara default. JS hanya di-load untuk komponen yang benar-benar butuh interactivity resulting in 99/100 Lighthouse performance score.
          </p>
        </div>

        <div class="cs-tech-card">
          <div class="cs-tech-icon"><i class="fas fa-layer-group"></i></div>
          <h3>Island Architecture</h3>
          <p>
            Setiap page adalah static HTML server-rendered. Interactive components (gallery filters, GLightbox, counters) di-load sebagai islands isolated, lazy-loaded JavaScript modules.
          </p>
        </div>

        <div class="cs-tech-card">
          <div class="cs-tech-icon"><i class="fas fa-code"></i></div>
          <h3>Multi-Framework Support</h3>
          <p>
            Bisa mixing React, Vue, Svelte, atau vanilla JS dalam satu project. Untuk portfolio ini, saya gunakan pure Astro components + vanilla JS untuk keep it lean dan performant.
          </p>
        </div>

        <div class="cs-tech-card">
          <div class="cs-tech-icon"><i class="fas fa-rocket"></i></div>
          <h3>Static Generation + Vercel Edge</h3>
          <p>
            Static site generation untuk instant page loads, dengan Vercel Edge Network untuk global CDN distribution. Setiap deployment otomatis trigger ISR-like behavior.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- PAGE STRUCTURE -->
  <section class="cs-section" transition:animate="fade">
    <div class="cs-inner">
      <div class="fade-up">
        <span class="cs-section-label gradient-label">ARCHITECTURE</span>
        <h2 class="cs-section-title">Site Structure</h2>
      </div>
      <div class="cs-arch-grid fade-up">
        <div class="cs-arch-tree">
          <div class="cs-arch-root">for-portfolio-mu.vercel.app</div>
          <ul class="cs-arch-list">
            <li><a href="/" class="cs-arch-page">/ → Home (Hero, About, Services, Testimonials, Contact)</a></li>
            <li><a href="/about" class="cs-arch-page">/about → Full Bio, Skills, Process, CTA</a></li>
            <li><a href="/foto" class="cs-arch-page">/foto → Photography Gallery + Filters</a></li>
            <li><a href="/video" class="cs-arch-page">/video → Videography Showcase</a></li>
            <li><a href="/design" class="cs-arch-page">/design → Brand Design Portfolio</a></li>
            <li><a href="/website" class="cs-arch-page">/website → Web Dev Projects</a></li>
            <li><a href="/case-study/..." class="cs-arch-page">/case-study/* → Detailed Project Writeups</a></li>
          </ul>
        </div>
        <div class="cs-arch-components">
          <div class="cs-arch-label">Component Architecture</div>
          <div class="cs-arch-comp-list">
            <span class="cs-arch-comp">BaseLayout.astro</span>
            <span class="cs-arch-comp">Navbar.astro</span>
            <span class="cs-arch-comp">Footer.astro</span>
            <span class="cs-arch-comp">ServiceCard.astro</span>
            <span class="cs-arch-comp">TestimonialCard.astro</span>
            <span class="cs-arch-comp">GalleryItem.astro</span>
            <span class="cs-arch-comp">PortfolioCTA.astro</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- PERFORMANCE RESULTS -->
  <section class="cs-section" transition:animate="fade">
    <div class="cs-inner">
      <div class="fade-up">
        <span class="cs-section-label gradient-label">RESULTS</span>
        <h2 class="cs-section-title">Performance Metrics</h2>
      </div>
      <div class="cs-performance-grid fade-up">
        <div class="cs-performance-card cs-performance-grade-a">
          <div class="cs-performance-label">Performance</div>
          <div class="cs-performance-score">98/100</div>
          <div class="cs-performance-bar-wrap">
            <div class="cs-performance-bar" style="width: 98%;"></div>
          </div>
        </div>
        <div class="cs-performance-card cs-performance-grade-a">
          <div class="cs-performance-label">Accessibility</div>
          <div class="cs-performance-score">100/100</div>
          <div class="cs-performance-bar-wrap">
            <div class="cs-performance-bar" style="width: 100%;"></div>
          </div>
        </div>
        <div class="cs-performance-card cs-performance-grade-a">
          <div class="cs-performance-label">Best Practices</div>
          <div class="cs-performance-score">100/100</div>
          <div class="cs-performance-bar-wrap">
            <div class="cs-performance-bar" style="width: 100%;"></div>
          </div>
        </div>
        <div class="cs-performance-card cs-performance-grade-a">
          <div class="cs-performance-label">SEO</div>
          <div class="cs-performance-score">100/100</div>
          <div class="cs-performance-bar-wrap">
            <div class="cs-performance-bar" style="width: 100%;"></div>
          </div>
        </div>
      </div>
      <div class="cs-performance-highlights fade-up">
        <div class="cs-ph">
          <i class="fas fa-clock"></i>
          <div>
            <p class="cs-ph-title">LCP: 1.8s</p>
            <p class="cs-ph-desc">Hero image preloaded, critical CSS inlined</p>
          </div>
        </div>
        <div class="cs-ph">
          <i class="fas fa-tachometer-alt"></i>
          <div>
            <p class="cs-ph-title">FID: 0ms</p>
            <p class="cs-ph-desc">Zero render-blocking JS on initial load</p>
          </div>
        </div>
        <div class="cs-ph">
          <i class="fas fa-weight"></i>
          <div>
            <p class="cs-ph-title">Total JS: 42KB</p>
            <p class="cs-ph-desc">GZipped, lazy-loaded only what's needed</p>
          </div>
        </div>
        <div class="cs-ph">
          <i class="fas fa-shield-alt"></i>
          <div>
            <p class="cs-ph-title">HTTPS + HTTP/2</p>
            <p class="cs-ph-desc">Powered by Vercel Edge Network</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- LESSONS LEARNED -->
  <section class="cs-section" transition:animate="fade">
    <div class="cs-inner">
      <div class="fade-up">
        <span class="cs-section-label gradient-label">REFLECTION</span>
        <h2 class="cs-section-title">What I Learned</h2>
      </div>
      <div class="cs-lessons fade-up">
        <div class="cs-lesson">
          <div class="cs-lesson-icon"><i class="fas fa-pen-nib"></i></div>
          <div>
            <h3>Design System First</h3>
            <p>
              Mendefinisikan CSS design tokens di awal (colors, typography, spacing, radius) membuat development fase akhir 2x lipat lebih cepat. Dengan design tokens yang solid, styling antar halaman jadi konsisten tanpa effort tambahan.
            </p>
          </div>
        </div>
        <div class="cs-lesson">
          <div class="cs-lesson-icon"><i class="fas fa-mobile-alt"></i></div>
          <div>
            <h3>Mobile-First Saves Time</h3>
            <p>
              Approach mobile-first bukan hanya best practice ini literally lebih cepat dalam development. Styling dari mobile di-extend ke atas lebih mudah daripada dari desktop di-collapse ke bawah. Setiap breakpoint punya alasan yang jelas.
            </p>
          </div>
        </div>
        <div class="cs-lesson">
          <div class="cs-lesson-icon"><i class="fas fa-search"></i></div>
          <div>
            <h3>SEO is Structural</h3>
            <p>
              SEO yang baik dimulai dari architecture, bukan dari plugins. Semantic HTML, proper heading hierarchy, OG tags yang konsisten, dan JSON-LD structured data semua itu lebih impact daripada keyword stuffing.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- NEXT PROJECT CTA -->
  <PortfolioCTA />

  <!-- Footer -->
  <Footer slot="footer" variant="minimal" />
</BaseLayout>

<style>
  /* ===== HERO ===== */
  .cs-hero {
    position: relative;
    padding: 120px 64px 0;
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .cs-hero-glow {
    position: absolute;
    top: -10%;
    right: -5%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(163, 166, 255, 0.08) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
  }

  .cs-hero-inner {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .cs-hero-meta {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .cs-category-badge {
    display: inline-flex;
    padding: 5px 14px;
    border-radius: 9999px;
    background: rgba(163, 166, 255, 0.12);
    border: 1px solid rgba(163, 166, 255, 0.2);
    color: var(--accent-primary);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .cs-year {
    font-size: 13px;
    color: var(--on-surface-variant);
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
  }

  .cs-hero-title {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(36px, 4vw, 60px);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -1.5px;
    color: var(--on-surface);
  }

  .cs-hero-accent {
    color: var(--accent-primary);
    font-style: italic;
  }

  .cs-hero-sub {
    font-size: 15px;
    line-height: 1.8;
    color: var(--on-surface-variant);
    max-width: 480px;
  }

  .cs-hero-stats {
    display: flex;
    gap: 24px;
    margin-top: 12px;
    flex-wrap: wrap;
  }

  .cs-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cs-stat-num {
    font-family: 'Manrope', sans-serif;
    font-size: 24px;
    font-weight: 800;
    color: var(--accent-primary);
    letter-spacing: -0.5px;
    line-height: 1;
  }

  .cs-stat-label {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--on-surface-variant);
  }

  .cs-hero-image {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(163, 166, 255, 0.08);
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.5);
  }

  .cs-hero-image img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
  }

  .cs-hero-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(6, 14, 32, 0.4), transparent 60%);
  }

  /* ===== SECTIONS ===== */
  .cs-section {
    padding: 80px 0;
  }

  .cs-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 64px;
  }

  .cs-section-label {
    display: inline-block;
    font-family: 'Manrope', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-primary);
    margin-bottom: 12px;
  }

  .gradient-label {
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cs-section-title {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 800;
    color: var(--on-surface);
    letter-spacing: -0.5px;
    line-height: 1.15;
    margin-bottom: 32px;
  }

  .section-divider {
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(163, 166, 255, 0.12) 20%,
      rgba(193, 128, 255, 0.12) 80%,
      transparent
    );
    margin: 0 64px;
  }

  /* ===== OVERVIEW ===== */
  .cs-overview-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 80px;
    align-items: start;
  }

  .cs-overview-left p {
    font-size: 15px;
    line-height: 1.85;
    color: var(--on-surface-variant);
    margin-bottom: 16px;
  }

  .cs-info-card {
    background: var(--surface-container);
    border: 1px solid rgba(163, 166, 255, 0.08);
    border-radius: 20px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cs-info-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 14px 0;
    border-bottom: 1px solid rgba(163, 166, 255, 0.06);
    gap: 16px;
  }

  .cs-info-row:last-child {
    border-bottom: none;
  }

  .cs-info-label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--on-surface-variant);
    flex-shrink: 0;
  }

  .cs-info-value {
    font-size: 13px;
    color: var(--on-surface);
    text-align: right;
    font-family: 'Inter', sans-serif;
  }

  /* ===== DESIGN SYSTEM ===== */
  .cs-design-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .cs-design-block {
    background: var(--surface-container);
    border: 1px solid rgba(163, 166, 255, 0.08);
    border-radius: 16px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .cs-design-block-wide {
    grid-column: span 3;
  }

  .cs-design-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--on-surface-variant);
  }

  .cs-design-swatches {
    display: flex;
    gap: 8px;
  }

  .cs-swatch {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    cursor: default;
    transition: transform 0.2s ease;
  }

  .cs-swatch:hover {
    transform: scale(1.1);
  }

  .cs-design-typo {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cs-design-code {
    background: var(--surface-container-highest);
    border-radius: 10px;
    padding: 16px;
    overflow-x: auto;
  }

  .cs-design-code pre {
    font-family: 'Fira Code', 'Cascadia Code', monospace;
    font-size: 12px;
    color: var(--accent-primary);
    line-height: 1.8;
    margin: 0;
    white-space: pre;
  }

  /* ===== TECH ===== */
  .cs-tech-header {
    margin-bottom: 48px;
  }

  .cs-tech-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .cs-tech-card {
    background: var(--surface-container);
    border: 1px solid rgba(163, 166, 255, 0.08);
    border-radius: 20px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: transform 0.4s ease, border-color 0.3s ease;
