---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PortfolioCTA from '../components/PortfolioCTA.astro';
---

<BaseLayout
  title="Video Portfolio | Frame Of Rangga"
  description="Portofolio videografi Rangga Danuarta — brand video, dokumentasi event, konten sosial media, dan video promosi dengan pendekatan cinematic storytelling."
  ogImage="https://for-portfolio-mu.vercel.app/assets/og/og-video.jpg"
  ogUrl="https://for-portfolio-mu.vercel.app/video"
  hasGlightbox={true}
>
  <Navbar slot="navbar" activePage="video" />

  <section class="gallery-section" transition:animate="fade">
    <h1 class="fade-up">Video Portfolio</h1>
    <p class="gallery-subtitle fade-up">Koleksi video brand, dokumentasi event, dan konten kreatif dengan pendekatan cinematic storytelling</p>

    <!-- Update notice -->
    <div class="update-notice fade-up">
      <i class="fas fa-film"></i>
      <span>Video portfolio sedang dalam proses update. <a href="https://wa.me/62895321693131" target="_blank" rel="noopener noreferrer">Hubungi via WhatsApp</a> untuk melihat showreel lengkap.</span>
    </div>

    <!-- Filter Bar -->
    <div class="filter-bar fade-up" aria-label="Filter by category">
      <button class="filter-btn active" data-filter="all">Semua</button>
      <button class="filter-btn" data-filter="brand">Brand Video</button>
      <button class="filter-btn" data-filter="dokumentasi">Dokumentasi</button>
      <button class="filter-btn" data-filter="sosmed">Konten Sosial Media</button>
      <button class="filter-btn" data-filter="promosi">Promosi</button>
    </div>

    <!-- Video Grid -->
    <div class="video-grid fade-up">

      <!-- Card 1: Brand Video -->
      <!-- GANTI: YouTube video ID kamu (dari URL youtube.com/watch?v=XXXX) -->
      <a class="glightbox video-card"
         href="https://www.youtube.com/watch?v=dQw4w9WgXcQ"
         data-type="video"
         data-source="youtube"
         data-gallery="videos"
         data-category="brand">
        <div class="thumbnail-wrapper">
          <img src="/assets/thumbnails/ss keyboard.png" alt="Brand Video" loading="lazy" />
          <div class="play-overlay">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </div>
          <span class="duration-badge">3:45</span>
          <span class="category-badge">Brand Video</span>
        </div>
        <div class="card-info">
          <h3>Brand Video: Client Project</h3>
          <p>Video campaign dengan pendekatan cinematic storytelling untuk brand.</p>
        </div>
      </a>

      <!-- Card 2: Dokumentasi -->
      <!-- GANTI: YouTube video ID kamu (dari URL youtube.com/watch?v=XXXX) -->
      <a class="glightbox video-card"
         href="https://www.youtube.com/watch?v=dQw4w9WgXcQ"
         data-type="video"
         data-source="youtube"
         data-gallery="videos"
         data-category="dokumentasi">
        <div class="thumbnail-wrapper">
          <img src="/assets/thumbnails/ss laptop.png" alt="Dokumentasi Event" loading="lazy" />
          <div class="play-overlay">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </div>
          <span class="duration-badge">5:20</span>
          <span class="category-badge">Dokumentasi</span>
        </div>
        <div class="card-info">
          <h3>Dokumentasi Event</h3>
          <p>Coverage acara dan event dengan hasil yang dinamis dan emosional.</p>
        </div>
      </a>

      <!-- Card 3: Konten Sosial Media -->
      <!-- GANTI: YouTube video ID kamu (dari URL youtube.com/watch?v=XXXX) -->
      <a class="glightbox video-card"
         href="https://www.youtube.com/watch?v=dQw4w9WgXcQ"
         data-type="video"
         data-source="youtube"
         data-gallery="videos"
         data-category="sosmed">
        <div class="thumbnail-wrapper">
          <img src="/assets/thumbnails/web1.png" alt="Konten Sosmed" loading="lazy" />
          <div class="play-overlay">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </div>
          <span class="duration-badge">0:30</span>
          <span class="category-badge">Konten Sosial Media</span>
        </div>
        <div class="card-info">
          <h3>Konten Sosial Media</h3>
          <p>Short-form content yang engaging untuk Instagram, TikTok, dan YouTube Shorts.</p>
        </div>
      </a>

      <!-- Card 4: Promosi -->
      <!-- GANTI: YouTube video ID kamu (dari URL youtube.com/watch?v=XXXX) -->
      <a class="glightbox video-card"
         href="https://www.youtube.com/watch?v=dQw4w9WgXcQ"
         data-type="video"
         data-source="youtube"
         data-gallery="videos"
         data-category="promosi">
        <div class="thumbnail-wrapper">
          <img src="/assets/thumbnails/web2.png" alt="Video Promosi" loading="lazy" />
          <div class="play-overlay">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </div>
          <span class="duration-badge">1:00</span>
          <span class="category-badge">Promosi</span>
        </div>
        <div class="card-info">
          <h3>Video Promosi Produk</h3>
          <p>Video iklan yang langsung nge-hit target audiens dan boost conversion.</p>
        </div>
      </a>

    </div>
  </section>

  <PortfolioCTA />

  <Footer slot="footer" variant="minimal" />
</BaseLayout>

<script>
  /* ---------- GLIGHTBOX (YouTube embed) ---------- */
  document.addEventListener('DOMContentLoaded', function initGL() {
    if (typeof GLightbox === 'undefined') {
      setTimeout(initGL, 100);
      return;
    }
    GLightbox({
      selector: '.glightbox',
      touchNavigation: true,
      loop: false,
      autoplayVideos: true,
    });
  });

  /* ---------- VIDEO FILTER ---------- */
  document.addEventListener('DOMContentLoaded', function init() {
    const filterBar = document.querySelector('.filter-bar');
    if (!filterBar) return;

    const btns = filterBar.querySelectorAll('.filter-btn');
    const grid = document.querySelector('.video-grid');
    if (!grid) return;

    btns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        const filter = btn.dataset.filter;

        // Update active button
        btns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');

        // Show/hide cards
        const cards = grid.querySelectorAll('.video-card');
        cards.forEach(function(card) {
          const cat = card.dataset.category || '';
          if (filter === 'all' || cat === filter) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  });
</script>
