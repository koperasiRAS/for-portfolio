---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import { waLink } from '../utils/whatsapp.js';
---

<BaseLayout
  title="Frame Of Rangga | Visual Storyteller — Foto, Video, Design & Web"
  description="Rangga Danuarta, Visual Storyteller berbasis di Depok. Spesialis fotografi komersial, videografi, brand design, dan web development untuk brand dan bisnis Anda."
  ogImage="https://for-portfolio-mu.vercel.app/assets/og/og-default.jpg"
  ogUrl="https://for-portfolio-mu.vercel.app/"
  hasHeroPreload={true}
>
  <!-- Navbar slot -->
  <Navbar slot="navbar" activePage="home" />

  <!-- HERO -->
  <header class="hero" id="hero" transition:animate="fade">
    <div class="hero-bg-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <!-- Left: Copy -->
      <div class="hero-content fade-up">
        <span class="hero-badge">
          <i class="fas fa-star"></i> Visual Storyteller
        </span>
        <h1 class="hero-headline">
          Frame<br>Of<br>
          <span class="text-glow">Rangga</span>
        </h1>
        <p class="hero-sub">
          Menciptakan karya visual yang bercerita dan berkarakter. Mari kita bangun narasi visual dan brand presence yang kuat.
        </p>
        <div class="hero-cta">
          <a href="/design" class="btn btn-primary">
            <i class="fas fa-folder-open"></i> See Projects
          </a>
          <a href="#contact" class="btn btn-ghost">
            <i class="fas fa-paper-plane"></i> Contact
          </a>
        </div>
      </div>

      <!-- Right: Portrait -->
      <div class="hero-portrait fade-up">
        <div class="hero-portrait-wrap">
          <img
            src="/assets/foto/foto cover halaman utama.jpg"
            alt="Rangga Danuarta - Frame Of Rangga"
            loading="eager"
            fetchpriority="high"
            onerror="this.style.display='none'"
          />
          <div class="hero-portrait-glow" aria-hidden="true"></div>
        </div>
        <div class="hero-experience-badge" aria-label="Experience badge">
          <strong>4+</strong>
          <span>Years<br>Experience</span>
        </div>
      </div>
    </div>

    <!-- Preview Categories -->
    <div class="hero-previews">
      <p class="preview-section-label">Explore Categories</p>
      <div class="preview-grid fade-up">
        <a href="/foto" class="preview-card">
          <img src="/assets/foto/fotografer/fotografi gojek.jpg" alt="Photography portfolio preview" loading="lazy" width="600" height="400" onerror="this.style.display='none'" />
          <div class="preview-overlay">
            <div class="preview-overlay-content">
              <i class="fas fa-camera"></i>
              <span class="preview-overlay-title">Photography</span>
              <span class="preview-overlay-arrow"><i class="fas fa-arrow-right"></i></span>
            </div>
          </div>
        </a>
        <a href="/video" class="preview-card">
          <img src="/assets/thumbnails/ss keyboard.png" alt="Video portfolio preview" loading="lazy" width="600" height="400" onerror="this.style.display='none'" />
          <div class="preview-overlay">
            <div class="preview-overlay-content">
              <i class="fas fa-play"></i>
              <span class="preview-overlay-title">Video</span>
              <span class="preview-overlay-arrow"><i class="fas fa-arrow-right"></i></span>
            </div>
          </div>
        </a>
        <a href="/design" class="preview-card">
          <img src="/assets/design/brand/desain elektronik.png" alt="Design portfolio preview" loading="lazy" width="600" height="400" onerror="this.style.display='none'" />
          <div class="preview-overlay">
            <div class="preview-overlay-content">
              <i class="fas fa-palette"></i>
              <span class="preview-overlay-title">Design</span>
              <span class="preview-overlay-arrow"><i class="fas fa-arrow-right"></i></span>
            </div>
          </div>
        </a>
        <a href="/website" class="preview-card">
          <img src="/assets/thumbnails/web1.png" alt="Web Development portfolio preview" loading="lazy" width="600" height="400" onerror="this.style.display='none'" />
          <div class="preview-overlay">
            <div class="preview-overlay-content">
              <i class="fas fa-code"></i>
              <span class="preview-overlay-title">Web Dev</span>
              <span class="preview-overlay-arrow"><i class="fas fa-arrow-right"></i></span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </header>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- ABOUT -->
  <section class="about" id="about" transition:animate="fade">
    <div class="about-inner">
      <div class="about-photo fade-up">
        <div class="about-photo-wrap">
          <img src="/assets/foto/about rangga.jpg" alt="Rangga Danuarta" loading="lazy" onerror="this.style.display='none'" />
        </div>
      </div>
      <div class="about-text fade-up">
        <span class="section-label gradient-label">TENTANG FOR</span>
        <h2 class="section-title">About Me</h2>
        <p class="about-bio">
          Saya Rangga Danuarta, seorang Visual Storyteller dan Creative Professional berbasis di Depok, Indonesia. Dengan pengalaman lebih dari 4 tahun di bidang fotografi, videografi, brand design, dan web development, saya berdedikasi untuk menghadirkan karya visual yang tidak hanya estetis, tetapi juga berdampak nyata bagi brand dan bisnis klien.
        </p>
        <p class="about-bio">
          Setiap project dikerjakan dengan pendekatan yang terstruktur: mulai dari riset mendalam, pengembangan konsep, eksekusi teknis, hingga final delivery yang memenuhi standar kualitas tertinggi. Saya percaya bahwa visual yang kuat adalah fondasi dari komunikasi brand yang efektif.
        </p>
        <div class="about-stats">
          <div class="stat-card">
            <span class="stat-number" data-target="4">0</span>
            <span class="stat-label">Years</span>
          </div>
          <div class="stat-card">
            <span class="stat-number" data-target="30">0</span>
            <span class="stat-label">Projects</span>
          </div>
          <div class="stat-card">
            <span class="stat-number" data-target="4">0</span>
            <span class="stat-label">Services</span>
          </div>
        </div>
        <a href={waLink('collab')} target="_blank" rel="noopener" class="btn btn-ghost">
          <i class="fab fa-whatsapp"></i> Chat via WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- BRANDS -->
  <section class="brands" id="brands" transition:animate="fade">
    <div class="brands-inner fade-up">
      <p class="brands-label">Trusted by brands &amp; clients</p>
      <div class="logo-strip">
        <div class="logo-item">
          <img src="/assets/logos/ptnr-tokopedia.png" alt="Tokopedia" loading="lazy" />
        </div>
        <div class="logo-item">
          <img src="/assets/logos/ptnr-kitabisa.png" alt="KitaBisa" loading="lazy" />
        </div>
        <div class="logo-item">
          <img src="/assets/logos/ptnr-shopee.png" alt="Shopee" loading="lazy" />
        </div>
        <div class="logo-item">
          <img src="/assets/logos/ptnr-bankqurban.png" alt="Bank Qurban" loading="lazy" />
        </div>
        <div class="logo-item">
          <img src="/assets/logos/ptnr-shinepartner.png" alt="Shinepartner" loading="lazy" />
        </div>
        <div class="logo-item">
          <img src="/assets/logos/ptnr-mandiri.png" alt="Mandiri" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- SERVICES -->
  <section class="services" id="services" transition:animate="fade">
    <div class="services-inner">
      <div class="services-header fade-up">
        <span class="section-label gradient-label">WHAT I DO</span>
        <h2 class="section-title">Services</h2>
        <p class="section-sub">Solusi kreatif lengkap untuk brand dan bisnis Anda</p>
      </div>
      <div class="services-grid">
        <ServiceCard
          icon="fas fa-camera"
          title="Photography"
          description="Foto komersial, wedding, editorial, dan automotive dengan pendekatan storytelling yang kuat dan estetik yang tajam."
          whatsappKey="foto_general"
        />
        <ServiceCard
          icon="fas fa-video"
          title="Videography"
          description="Produksi video mulai dari konsep hingga final cut. Cocok untuk konten brand, dokumentasi acara, dan video promosi."
          whatsappKey="video_general"
        />
        <ServiceCard
          icon="fas fa-palette"
          title="Brand Design"
          description="Identitas visual, desain sosial media, poster, dan materi iklan yang membangun karakter brand secara konsisten."
          whatsappKey="design_general"
        />
        <ServiceCard
          icon="fas fa-code"
          title="Web Development"
          description="Website portofolio, landing page, dan undangan digital yang responsif, cepat, dan berorientasi pada pengalaman pengguna."
          whatsappKey="web_general"
        />
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"></div>



  <!-- TESTIMONIALS -->
  <section class="testimonials" id="testimonials" transition:animate="fade">
    <div class="testimonials-inner">
      <div class="testimonials-header fade-up">
        <span class="section-label">Reviews</span>
        <h2 class="section-title">Kata Mereka</h2>
      </div>
      <div class="testimonials-scroll">
        <TestimonialCard
          quote="Rangga berhasil menangkap esensi brand kami dengan sangat baik. Hasil fotonya melebihi ekspektasi dan proses kerjanya sangat profesional."
          name="Tim Kreatif Tokopedia"
          role="Brand Team"
          initials="TK"
        />
        <TestimonialCard
          quote="Video campaign yang dibuat Rangga berhasil meningkatkan engagement kami secara signifikan. Storytelling-nya autentik dan emosional."
          name="KitaBisa.com"
          role="Marketing Division"
          initials="KB"
        />
        <TestimonialCard
          quote="Desain brand identity dari Rangga sangat on-point. Beliau memahami kebutuhan bisnis dan menterjemahkannya ke visual yang powerful."
          name="Shinepartner"
          role="Brand Owner"
          initials="SP"
        />
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- CONTACT -->
  <section class="contact" id="contact" transition:animate="fade">
    <div class="contact-inner fade-up">
      <div class="contact-header">
        <span class="section-label gradient-label">GET IN TOUCH</span>
        <h2 class="section-title">Let's Create Together</h2>
        <p class="section-sub">Hubungi saya untuk kolaborasi dan proyek kreatif berikutnya.</p>
      </div>

      <!-- Contact Form -->
      <form id="contact-form" class="contact-form stitch-form" novalidate>
        <!-- Honeypot — bot-only, hidden from humans -->
        <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0;" />

        <div class="form-row">
          <div class="form-group">
            <label for="name">Nama</label>
            <input type="text" id="name" name="name" placeholder="Nama lengkap" autocomplete="name" />
            <span class="form-error" id="name-error"></span>
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="email@contoh.com" autocomplete="email" />
            <span class="form-error" id="email-error"></span>
          </div>
        </div>
        <div class="form-group">
          <label for="project">Jenis Project</label>
          <select id="project" name="project">
            <option value="" disabled selected>Pilih jenis project</option>
            <option value="Photography">Photography</option>
            <option value="Videography">Videography</option>
            <option value="Brand Design">Brand Design</option>
            <option value="Web Development">Web Development</option>
            <option value="Lainnya">Lainnya</option>
          </select>
          <span class="form-error" id="project-error"></span>
        </div>
        <div class="form-group">
          <label for="message">Pesan</label>
          <textarea id="message" name="message" rows="5" placeholder="Ceritakan project yang ingin dibuat..."></textarea>
          <span class="form-error" id="message-error"></span>
        </div>

        <!-- Status messages -->
        <div id="form-success" class="form-message form-success" style="display:none;">
          <i class="fas fa-check-circle"></i> Pesan terkirim! Saya akan menghubungi Anda dalam 1x24 jam.
        </div>
        <div id="form-error-msg" class="form-message form-error-msg" style="display:none;">
          <i class="fas fa-exclamation-circle"></i> Gagal mengirim. Silakan hubungi via WhatsApp.
        </div>

        <div class="form-submit">
          <button type="submit" id="submit-btn" class="btn btn-primary">
            <i class="fas fa-paper-plane"></i> Kirim Pesan
          </button>
        </div>
      </form>

      <div class="contact-divider">
        <span>atau hubungi langsung</span>
      </div>
      <div class="contact-buttons">
        <a href={waLink('contact')} target="_blank" rel="noopener" class="btn btn-ghost">
          <i class="fab fa-whatsapp"></i> WhatsApp
        </a>
        <a href="https://instagram.com/frameofrangga" target="_blank" rel="noopener" class="btn btn-ghost">
          <i class="fab fa-instagram"></i> Instagram
        </a>
        <a href="https://www.tiktok.com/@madebyrangga" target="_blank" rel="noopener" class="btn btn-ghost">
          <i class="fab fa-tiktok"></i> TikTok
        </a>
      </div>
    </div>
  </section>

  <!-- Footer slot -->
  <Footer slot="footer" variant="full" />

  <!-- JSON-LD Person Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Rangga Danuarta",
    "jobTitle": "Visual Storyteller",
    "description": "Fotografer, Videografer, Brand Designer, dan Web Developer berbasis di Depok, Indonesia",
    "url": "https://for-portfolio-mu.vercel.app",
    "image": "https://for-portfolio-mu.vercel.app/assets/foto/about rangga.jpg",
    "email": "frameofrangga@gmail.com",
    "telephone": "+62895321693131",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Depok",
      "addressCountry": "ID"
    },
    "sameAs": [
      "https://instagram.com/frameofrangga",
      "https://www.tiktok.com/@madebyrangga"
    ],
    "knowsAbout": [
      "Photography", "Videography", "Brand Design",
      "Web Development", "Visual Storytelling"
    ]
  }
  </script>
</BaseLayout>

<style>
  /* =============================================
     HOME PAGE — Mobile & iPad Responsive
     ============================================= */

  /* iPad: hero 2-column stays, adjust spacing */
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 32px 24px;
      text-align: center;
    }
    .hero-content {
      align-items: center;
    }
    .hero-sub {
      max-width: 100%;
    }
    .hero-cta {
      justify-content: center;
    }
    .hero-portrait {
      max-width: 360px;
      margin: 0 auto;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
    }
    .hero-headline {
      font-size: clamp(48px, 12vw, 72px);
    }
    .preview-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    .about-inner {
      grid-template-columns: 1fr;
      gap: 48px;
      padding: 0 24px;
    }
    .about-text {
      text-align: center;
    }
    .about-stats {
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .hero-inner {
      padding: 24px 20px 40px;
    }
    .hero-headline {
      font-size: clamp(40px, 14vw, 60px);
      letter-spacing: -1px;
    }
    .hero-badge {
      font-size: 10px;
      padding: 6px 12px;
    }
    .hero-portrait {
      max-width: 280px;
    }
    .hero-experience-badge {
      right: 0;
      bottom: 16px;
      padding: 10px 14px;
    }
    .hero-experience-badge strong {
      font-size: 22px;
    }
    .preview-grid {
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }
    .preview-card {
      aspect-ratio: 1 / 1;
    }
    .preview-overlay {
      opacity: 1;
      background: linear-gradient(to top, rgba(15, 25, 48, 0.7) 0%, transparent 60%);
    }
    .preview-overlay-content {
      padding: 12px;
    }
    .preview-overlay-content i {
      font-size: 14px;
    }
    .preview-overlay-title {
      font-size: 11px;
    }
    .preview-overlay-arrow {
      display: none;
    }
    .about-inner {
      padding: 0 20px;
      gap: 32px;
    }
    .about-bio {
      font-size: 14px;
    }
    .about-stats {
      gap: 12px;
    }
    .section-title {
      font-size: 28px;
    }
  }
</style>

<script>
  function animateCounters() {
    const counters = document.querySelectorAll('.stat-number[data-target]');
    if (!counters.length) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target;
        const target = parseInt(el.dataset.target, 10);
        const duration = 2000;
        const startTime = performance.now();

        function tick(now) {
          const elapsed = now - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.round(eased * target) + '+';
          if (progress < 1) {
            requestAnimationFrame(tick);
          } else {
            el.textContent = target + '+';
          }
        }

        requestAnimationFrame(tick);
        observer.unobserve(el);
      });
    }, { threshold: 0.5 });

    counters.forEach(el => observer.observe(el));
  }
  document.addEventListener('DOMContentLoaded', function() {
    animateCounters();
  });

  /* ---------- CONTACT FORM ---------- */
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error-msg');

  function showError(fieldId, msg) {
    const el = document.getElementById(fieldId + '-error');
    if (el) { el.textContent = msg; }
    const input = document.getElementById(fieldId);
    if (input) input.classList.add('input-error');
  }

  function clearError(fieldId) {
    const el = document.getElementById(fieldId + '-error');
    if (el) { el.textContent = ''; }
    const input = document.getElementById(fieldId);
    if (input) input.classList.remove('input-error');
  }

  function validateForm() {
    let valid = true;
    const name = document.getElementById('name').value.trim();
    const email = document.getElementById('email').value.trim();
    const project = document.getElementById('project').value;
    const message = document.getElementById('message').value.trim();

    clearError('name'); clearError('email');
    clearError('project'); clearError('message');

    if (!name) { showError('name', 'Nama harus diisi.'); valid = false; }
    if (!email) {
      showError('email', 'Email harus diisi.'); valid = false;
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showError('email', 'Format email tidak valid.'); valid = false;
    }
    if (!project) { showError('project', 'Pilih jenis project.'); valid = false; }
    if (!message) {
      showError('message', 'Pesan harus diisi.'); valid = false;
    } else if (message.length < 10) {
      showError('message', 'Pesan minimal 10 karakter.'); valid = false;
    }

    return valid;
  }

  if (form) {
    // Clear errors on input
    ['name', 'email', 'project', 'message'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.addEventListener('input', () => clearError(id));
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!validateForm()) return;

      // Loading state
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Mengirim...';
      successMsg.style.display = 'none';
      errorMsg.style.display = 'none';

      try {
        const formData = new FormData(form);
        const res = await fetch('https://formspree.io/f/xpqoyeez', {
          method: 'POST',
          body: formData,
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          form.reset();
          successMsg.style.display = 'flex';
          successMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        } else {
          errorMsg.style.display = 'flex';
        }
      } catch {
        errorMsg.style.display = 'flex';
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fas fa-paper-plane"></i> Kirim Pesan';
      }
    });
  }
</script>
