---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import { waLink } from '../utils/whatsapp.js';
---

<BaseLayout
  title="Frame Of Rangga | Visual Storyteller — Foto, Video, Design & Web"
  description="Rangga Danuarta, Visual Storyteller berbasis di Depok. Spesialis fotografi komersial, videografi, brand design, dan web development untuk brand dan bisnis Anda."
  ogImage="https://for-portfolio-mu.vercel.app/assets/og/og-default.jpg"
  ogUrl="https://for-portfolio-mu.vercel.app/"
  hasHeroPreload={true}
>
  <!-- Navbar slot -->
  <Navbar slot="navbar" activePage="home" />

  <!-- HERO — Stitch Nocturnal Design -->
  <header class="stitch-hero" id="hero" transition:animate="fade">
    <!-- Background glow blobs (desktop) -->
    <div class="stitch-hero-glow-r" aria-hidden="true"></div>
    <div class="stitch-hero-glow-l" aria-hidden="true"></div>

    <!-- Background image -->
    <div class="stitch-hero-bg" aria-hidden="true">
      <img
        src="/assets/foto/foto cover halaman utama.jpg"
        alt=""
        class="stitch-hero-bg-img"
        loading="eager"
        fetchpriority="high"
      />
      <div class="stitch-hero-bg-overlay"></div>
    </div>

    <!-- Hero grid: text left, portrait right -->
    <div class="stitch-hero-grid">
      <!-- Text Content -->
      <div class="stitch-hero-content">
        <!-- Badge -->
        <span class="stitch-badge">
          Visual Storyteller
        </span>
        <!-- H1 -->
        <h1 class="stitch-hero-title">
          Frame of<br />
          <span class="stitch-hero-title-accent">Rangga</span>
        </h1>
        <!-- Description -->
        <p class="stitch-hero-desc">
          Crafting visual narratives through the lens of cinematic precision and editorial depth. Creative Direction for the digital age.
        </p>
      </div>

      <!-- Portrait -->
      <div class="stitch-hero-portrait">
        <div class="stitch-hero-portrait-inner">
          <img
            src="/assets/foto/foto cover halaman utama.jpg"
            alt="Rangga Danuarta — Frame Of Rangga"
            class="stitch-hero-portrait-img"
            loading="eager"
            fetchpriority="high"
          />
          <!-- Floating badge -->
          <div class="stitch-hero-float-badge">
            <div class="stitch-float-badge-icon">
              <span class="material-symbols-outlined stitch-icon-filled">verified</span>
            </div>
            <div>
              <p class="stitch-float-badge-sub">Visual Storyteller</p>
              <p class="stitch-float-badge-name">Rangga Danuarta</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- EXPLORE CATEGORIES -->
  <section class="cat-section" id="categories" transition:animate="fade">
    <div class="cat-inner">
      <div class="cat-header fade-up">
        <h2 class="cat-title">Explore Categories</h2>
        <div class="cat-title-line"></div>
      </div>
      <div class="cat-grid">
        <a href="/foto" class="cat-card cat-card-foto">
          <img src="/assets/foto/foto cover halaman utama.jpg" alt="Photography portfolio" loading="lazy" />
          <div class="cat-card-overlay"></div>
          <div class="cat-card-content">
            <span class="cat-card-label">Capturing Essence</span>
            <h3 class="cat-card-title">Foto</h3>
            <p class="cat-card-desc">Editorial and high-fashion photography focused on texture and silhouette.</p>
          </div>
          <div class="cat-card-arrow">
            <span class="material-symbols-outlined">arrow_outward</span>
          </div>
        </a>
        <a href="/video" class="cat-card cat-card-video">
          <img src="/assets/video/thumbnails/thumbnail cover utama.jpg" alt="Videography portfolio" loading="lazy" />
          <div class="cat-card-overlay"></div>
          <div class="cat-card-content">
            <span class="cat-card-label">Motion Theory</span>
            <h3 class="cat-card-title">Video</h3>
            <p class="cat-card-desc">Cinematic storytelling and commercial motion direction.</p>
          </div>
        </a>
        <a href="/website" class="cat-card cat-card-website">
          <img src="/assets/website/cover website portfolio rangga.jpg" alt="Web development portfolio" loading="lazy" />
          <div class="cat-card-overlay"></div>
          <div class="cat-card-content">
            <span class="cat-card-label">Digital Canvas</span>
            <h3 class="cat-card-title">Website</h3>
            <p class="cat-card-desc">Immersive digital experiences built for performance and aesthetics.</p>
          </div>
        </a>
        <a href="/design" class="cat-card cat-card-design">
          <img src="/assets/design/cover design portfolio rangga.jpg" alt="Brand design portfolio" loading="lazy" />
          <div class="cat-card-overlay"></div>
          <div class="cat-card-content">
            <span class="cat-card-label">Visual Systems</span>
            <h3 class="cat-card-title">Design</h3>
            <p class="cat-card-desc">Brand identity and visual communication systems that resonate.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- ABOUT -->
  <section class="about" id="about" transition:animate="fade">
    <div class="about-inner">
      <div class="about-photo fade-up">
        <div class="about-photo-wrap">
          <img src="/assets/foto/about rangga.jpg" alt="Rangga Danuarta" loading="lazy" onerror="this.style.display='none'" />
        </div>
      </div>
      <div class="about-text fade-up">
        <span class="section-label gradient-label">TENTANG FOR</span>
        <h2 class="section-title">About Me</h2>
        <p class="about-bio">
          Saya Rangga Danuarta, seorang Visual Storyteller dan Creative Professional berbasis di Depok, Indonesia. Dengan pengalaman lebih dari 4 tahun di bidang fotografi, videografi, brand design, dan web development, saya berdedikasi untuk menghadirkan karya visual yang tidak hanya estetis, tetapi juga berdampak nyata bagi brand dan bisnis klien.
        </p>
        <p class="about-bio">
          Setiap project dikerjakan dengan pendekatan yang terstruktur: mulai dari riset mendalam, pengembangan konsep, eksekusi teknis, hingga final delivery yang memenuhi standar kualitas tertinggi. Saya percaya bahwa visual yang kuat adalah fondasi dari komunikasi brand yang efektif.
        </p>
        <div class="about-stats">
          <div class="stat-card">
            <span class="stat-number" data-target="4">0</span>
            <span class="stat-label">Years</span>
          </div>
          <div class="stat-card">
            <span class="stat-number" data-target="30">0</span>
            <span class="stat-label">Projects</span>
          </div>
          <div class="stat-card">
            <span class="stat-number" data-target="4">0</span>
            <span class="stat-label">Services</span>
          </div>
        </div>
        <a href={waLink('collab')} target="_blank" rel="noopener" class="btn btn-ghost">
          <i class="fab fa-whatsapp"></i> Chat via WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- BRANDS -->
  <section class="brands" id="brands" transition:animate="fade">
    <div class="brands-inner fade-up">
      <p class="brands-label">Trusted by brands &amp; clients</p>
      <div class="logo-strip">
        <div class="logo-item">
          <img src="/assets/logos/ptnr-tokopedia.png" alt="Tokopedia" loading="lazy" />
        </div>
        <div class="logo-item">
          <img src="/assets/logos/ptnr-kitabisa.png" alt="KitaBisa" loading="lazy" />
        </div>
        <div class="logo-item">
          <img src="/assets/logos/ptnr-shopee.png" alt="Shopee" loading="lazy" />
        </div>
        <div class="logo-item">
          <img src="/assets/logos/ptnr-bankqurban.png" alt="Bank Qurban" loading="lazy" />
        </div>
        <div class="logo-item">
          <img src="/assets/logos/ptnr-shinepartner.png" alt="Shinepartner" loading="lazy" />
        </div>
        <div class="logo-item">
          <img src="/assets/logos/ptnr-mandiri.png" alt="Mandiri" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- SERVICES -->
  <section class="services" id="services" transition:animate="fade">
    <div class="services-inner">
      <div class="services-header fade-up">
        <span class="section-label gradient-label">WHAT I DO</span>
        <h2 class="section-title">Services</h2>
        <p class="section-sub">Solusi kreatif lengkap untuk brand dan bisnis Anda</p>
      </div>
      <div class="services-grid">
        <ServiceCard
          icon="fas fa-camera"
          title="Photography"
          description="Foto komersial, wedding, editorial, dan automotive dengan pendekatan storytelling yang kuat dan estetik yang tajam."
          whatsappKey="foto_general"
        />
        <ServiceCard
          icon="fas fa-video"
          title="Videography"
          description="Produksi video mulai dari konsep hingga final cut. Cocok untuk konten brand, dokumentasi acara, dan video promosi."
          whatsappKey="video_general"
        />
        <ServiceCard
          icon="fas fa-palette"
          title="Brand Design"
          description="Identitas visual, desain sosial media, poster, dan materi iklan yang membangun karakter brand secara konsisten."
          whatsappKey="design_general"
        />
        <ServiceCard
          icon="fas fa-code"
          title="Web Development"
          description="Website portofolio, landing page, dan undangan digital yang responsif, cepat, dan berorientasi pada pengalaman pengguna."
          whatsappKey="web_general"
        />
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"></div>



  <!-- TESTIMONIALS -->
  <section class="testimonials" id="testimonials" transition:animate="fade">
    <div class="testimonials-inner">
      <div class="testimonials-header fade-up">
        <span class="section-label">Reviews</span>
        <h2 class="section-title">Kata Mereka</h2>
      </div>
      <div class="testimonials-scroll">
        <TestimonialCard
          quote="Rangga berhasil menangkap esensi brand kami dengan sangat baik. Hasil fotonya melebihi ekspektasi dan proses kerjanya sangat profesional."
          name="Tim Kreatif Tokopedia"
          role="Brand Team"
          initials="TK"
        />
        <TestimonialCard
          quote="Video campaign yang dibuat Rangga berhasil meningkatkan engagement kami secara signifikan. Storytelling-nya autentik dan emosional."
          name="KitaBisa.com"
          role="Marketing Division"
          initials="KB"
        />
        <TestimonialCard
          quote="Desain brand identity dari Rangga sangat on-point. Beliau memahami kebutuhan bisnis dan menterjemahkannya ke visual yang powerful."
          name="Shinepartner"
          role="Brand Owner"
          initials="SP"
        />
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- CONTACT -->
  <section class="contact" id="contact" transition:animate="fade">
    <div class="contact-inner fade-up">
      <div class="contact-header">
        <span class="section-label gradient-label">GET IN TOUCH</span>
        <h2 class="section-title">Let's Create Together</h2>
        <p class="section-sub">Hubungi saya untuk kolaborasi dan proyek kreatif berikutnya.</p>
      </div>

      <!-- Contact Form -->
      <form id="contact-form" class="contact-form stitch-form" novalidate>
        <!-- Honeypot — bot-only, hidden from humans -->
        <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0;" />

        <div class="form-row">
          <div class="form-group">
            <label for="name">Nama</label>
            <input type="text" id="name" name="name" placeholder="Nama lengkap" autocomplete="name" />
            <span class="form-error" id="name-error"></span>
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="email@contoh.com" autocomplete="email" />
            <span class="form-error" id="email-error"></span>
          </div>
        </div>
        <div class="form-group">
          <label for="project">Jenis Project</label>
          <select id="project" name="project">
            <option value="" disabled selected>Pilih jenis project</option>
            <option value="Photography">Photography</option>
            <option value="Videography">Videography</option>
            <option value="Brand Design">Brand Design</option>
            <option value="Web Development">Web Development</option>
            <option value="Lainnya">Lainnya</option>
          </select>
          <span class="form-error" id="project-error"></span>
        </div>
        <div class="form-group">
          <label for="message">Pesan</label>
          <textarea id="message" name="message" rows="5" placeholder="Ceritakan project yang ingin dibuat..."></textarea>
          <span class="form-error" id="message-error"></span>
        </div>

        <!-- Status messages -->
        <div id="form-success" class="form-message form-success" style="display:none;">
          <i class="fas fa-check-circle"></i> Pesan terkirim! Saya akan menghubungi Anda dalam 1x24 jam.
        </div>
        <div id="form-error-msg" class="form-message form-error-msg" style="display:none;">
          <i class="fas fa-exclamation-circle"></i> Gagal mengirim. Silakan hubungi via WhatsApp.
        </div>

        <div class="form-submit">
          <button type="submit" id="submit-btn" class="btn btn-primary">
            <i class="fas fa-paper-plane"></i> Kirim Pesan
          </button>
        </div>
      </form>

      <div class="contact-divider">
        <span>atau hubungi langsung</span>
      </div>
      <div class="contact-buttons">
        <a href={waLink('contact')} target="_blank" rel="noopener" class="btn btn-ghost">
          <i class="fab fa-whatsapp"></i> WhatsApp
        </a>
        <a href="https://instagram.com/frameofrangga" target="_blank" rel="noopener" class="btn btn-ghost">
          <i class="fab fa-instagram"></i> Instagram
        </a>
        <a href="https://www.tiktok.com/@madebyrangga" target="_blank" rel="noopener" class="btn btn-ghost">
          <i class="fab fa-tiktok"></i> TikTok
        </a>
      </div>
    </div>
  </section>

  <!-- Footer slot -->
  <Footer slot="footer" variant="full" />

  <!-- JSON-LD Person Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Rangga Danuarta",
    "jobTitle": "Visual Storyteller",
    "description": "Fotografer, Videografer, Brand Designer, dan Web Developer berbasis di Depok, Indonesia",
    "url": "https://for-portfolio-mu.vercel.app",
    "image": "https://for-portfolio-mu.vercel.app/assets/foto/about rangga.jpg",
    "email": "frameofrangga@gmail.com",
    "telephone": "+6287779560264",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Depok",
      "addressCountry": "ID"
    },
    "sameAs": [
      "https://instagram.com/frameofrangga",
      "https://www.tiktok.com/@madebyrangga"
    ],
    "knowsAbout": [
      "Photography", "Videography", "Brand Design",
      "Web Development", "Visual Storytelling"
    ]
  }
  </script>
</BaseLayout>

<style>
  /* =============================================
     STITCH HERO — Mobile-first responsive
     ============================================= */

  /* ---- BASE (MOBILE DEFAULT) ---- */
  .stitch-hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 80px 24px 48px;
  }

  /* Background glow blobs */
  .stitch-hero-glow-r {
    position: absolute;
    top: -10%;
    right: -10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(193, 128, 255, 0.12) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
    z-index: 1;
  }

  .stitch-hero-glow-l {
    position: absolute;
    bottom: -5%;
    left: -5%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(163, 166, 255, 0.1) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
    z-index: 1;
  }

  /* Background image */
  .stitch-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .stitch-hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.5;
    filter: grayscale(60%);
  }

  .stitch-hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(6, 14, 32, 0.6) 0%,
      rgba(6, 14, 32, 0.2) 40%,
      rgba(6, 14, 32, 0.4) 100%
    );
  }

  /* Hero grid: single column on mobile */
  .stitch-hero-grid {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
  }

  /* Content */
  .stitch-hero-content {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Badge pill */
  .stitch-badge {
    display: inline-flex;
    align-items: center;
    padding: 6px 16px;
    border-radius: 9999px;
    background: var(--surface-container-highest);
    border: 1px solid rgba(163, 166, 255, 0.12);
    color: var(--secondary);
    font-family: 'Manrope', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    width: fit-content;
  }

  /* H1 */
  .stitch-hero-title {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(52px, 14vw, 96px);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -2px;
    color: var(--on-surface);
  }

  .stitch-hero-title-accent {
    color: var(--accent-primary);
    font-style: italic;
  }

  /* Desc */
  .stitch-hero-desc {
    font-size: 15px;
    line-height: 1.75;
    color: var(--on-surface-variant);
    max-width: 520px;
  }

  /* Portrait */
  .stitch-hero-portrait {
    display: flex;
    justify-content: center;
  }

  .stitch-hero-portrait-inner {
    position: relative;
    width: 100%;
    max-width: 480px;
  }

  .stitch-hero-portrait-img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center top;
    border-radius: 24px;
    display: block;
    filter: grayscale(30%);
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.6);
  }

  /* Floating badge */
  .stitch-hero-float-badge {
    position: absolute;
    bottom: 20px;
    left: 20px;
    right: 20px;
    background: rgba(25, 37, 64, 0.75);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(64, 72, 93, 0.3);
    border-radius: 16px;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .stitch-float-badge-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(163, 166, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .stitch-icon-filled {
    font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    color: var(--accent-primary);
    font-size: 20px;
  }

  .stitch-float-badge-sub {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--on-surface-variant);
    margin-bottom: 2px;
  }

  .stitch-float-badge-name {
    font-family: 'Manrope', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: var(--on-surface);
  }

  /* ---- Material Symbols shared ---- */
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    display: inline-block;
    line-height: 1;
    text-transform: none;
    letter-spacing: normal;
    word-wrap: normal;
    white-space: nowrap;
    direction: ltr;
  }

  /* ---- MEDIA QUERY: TABLET (768px+) ---- */
  @media (min-width: 768px) {
    .stitch-hero {
      padding: 100px 48px 64px;
    }

    .stitch-hero-title {
      font-size: clamp(72px, 12vw, 120px);
    }

    .stitch-hero-desc {
      font-size: 16px;
    }

    .stitch-hero-portrait-inner {
      max-width: 400px;
    }

    .stitch-hero-float-badge {
      bottom: 24px;
      left: 24px;
      right: 24px;
    }
  }

  /* ---- MEDIA QUERY: DESKTOP (1024px+) ---- */
  @media (min-width: 1024px) {
    .stitch-hero {
      padding: 120px 64px 80px;
      min-height: 100vh;
    }

    /* Two-column grid */
    .stitch-hero-grid {
      grid-template-columns: 7fr 5fr;
      gap: 64px;
    }

    .stitch-hero-title {
      font-size: clamp(80px, 8vw, 128px);
      letter-spacing: -3px;
    }

    .stitch-hero-desc {
      max-width: 520px;
      font-size: 16px;
    }

    .stitch-hero-portrait {
      justify-content: flex-end;
    }

    .stitch-hero-portrait-inner {
      max-width: 100%;
    }

    .stitch-hero-float-badge {
      bottom: 24px;
      left: 24px;
      right: 24px;
    }

    /* Glow positions for large screens */
    .stitch-hero-glow-r {
      width: 600px;
      height: 600px;
    }
  }

  /* ---- EXISTING PAGE RESPONSIVE ---- */
  @media (max-width: 768px) {
    .about-inner {
      grid-template-columns: 1fr;
      gap: 48px;
      padding: 0 24px;
    }
    .about-text {
      text-align: center;
    }
    .about-stats {
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .about-inner {
      padding: 0 20px;
      gap: 32px;
    }
    .about-bio {
      font-size: 14px;
    }
    .about-stats {
      gap: 12px;
    }
    .section-title {
      font-size: 28px;
    }
  }

  /* ---- CATEGORIES SECTION ---- */
  .cat-section {
    padding: 80px 0;
    background: var(--surface-container);
  }

  .cat-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 24px;
  }

  .cat-header {
    margin-bottom: 48px;
  }

  .cat-title {
    font-family: 'Manrope', sans-serif;
    font-size: 36px;
    font-weight: 800;
    color: var(--on-surface);
    letter-spacing: -0.5px;
