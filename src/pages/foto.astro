---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import GalleryItem from '../components/GalleryItem.astro';
import PortfolioCTA from '../components/PortfolioCTA.astro';
---

<BaseLayout
  title="Photography Portfolio | Frame Of Rangga"
  description="Portofolio fotografi Rangga Danuarta — wedding, komersial, automotive, lifestyle, dan brand photography dengan pendekatan visual storytelling."
  ogImage="https://for-portfolio-mu.vercel.app/assets/og/og-foto.jpg"
  ogUrl="https://for-portfolio-mu.vercel.app/foto"
  hasGlightbox={true}
>
  <Navbar slot="navbar" activePage="foto" />

  <!-- PAGE HERO -->
  <section class="page-hero" transition:animate="fade">
    <div class="page-hero-bg-glow" aria-hidden="true"></div>
    <div class="page-hero-inner">
      <span class="section-label gradient-label">Portfolio</span>
      <h1 class="page-hero-title">Photography</h1>
      <p class="page-hero-sub">Momen-momen yang diabadikan dengan sentuhan visual yang kuat dan storytelling yang autentik.</p>
    </div>
  </section>

  <!-- CAROUSEL -->
  <section class="photo-carousel-section" transition:animate="fade">
    <div class="carousel-container fade-up">
      <div class="carousel-track" id="carouselTrack">
        <div class="carousel-slide">
          <img src="/assets/foto/wedding/ultah raden 2 landscape.JPG" alt="Wedding Photography" loading="lazy" />
        </div>
        <div class="carousel-slide">
          <img src="/assets/foto/wedding/anggie 2 landscape.jpg" alt="Portrait Photography" loading="lazy" />
        </div>
        <div class="carousel-slide">
          <img src="/assets/foto/wedding/anggie 4 landscape.jpg" alt="Editorial Photography" loading="lazy" />
        </div>
        <div class="carousel-slide">
          <img src="/assets/foto/fotografer/fotografi gojek.jpg" alt="Brand Photography" loading="lazy" />
        </div>
        <div class="carousel-slide">
          <img src="/assets/foto/fotografer/fotografi mobil.jpg" alt="Automotive Photography" loading="lazy" />
        </div>
        <div class="carousel-slide">
          <img src="/assets/foto/fotografer/ccm rangga.jpg" alt="Lifestyle Photography" loading="lazy" />
        </div>
        <div class="carousel-slide">
          <img src="/assets/foto/fashion/foto baju coklat.jpg" alt="Commercial Photography" loading="lazy" />
        </div>
      </div>
      <div class="carousel-dots" id="carouselDots"></div>
    </div>
  </section>

  <!-- FILTER + GALLERY -->
  <section class="gallery-section" transition:animate="fade">
    <!-- Filter Bar -->
    <div class="filter-bar fade-up" aria-label="Filter by category">
      <button class="filter-btn active" data-filter="all">Semua</button>
      <button class="filter-btn" data-filter="wedding">Wedding</button>
      <button class="filter-btn" data-filter="komersial">Komersial</button>
      <button class="filter-btn" data-filter="automotive">Automotive</button>
      <button class="filter-btn" data-filter="lifestyle">Lifestyle</button>
      <button class="filter-btn" data-filter="fotografer">Fotografer</button>
    </div>

    <!-- Gallery Grid -->
    <div class="gallery-grid gallery-grid-portrait fade-up">

      <!-- Wedding -->
      <div class="gallery-portrait-wrap">
        <GalleryItem
          src="/assets/foto/wedding/ultah raden 2 landscape.JPG"
          alt="Wedding Photography"
          title="Wedding: Ultah Raden"
          category="wedding"
          href="/assets/foto/wedding/ultah raden 2 landscape.JPG"
          gallery="portfolio-gallery"
        />
      </div>
      <div class="gallery-portrait-wrap">
        <GalleryItem
          src="/assets/foto/wedding/anggie 2 landscape.jpg"
          alt="Portrait Photography"
          title="Wedding: Anggie"
          category="wedding"
          href="/assets/foto/wedding/anggie 2 landscape.jpg"
          gallery="portfolio-gallery"
        />
      </div>
      <div class="gallery-portrait-wrap">
        <GalleryItem
          src="/assets/foto/wedding/anggie 4 landscape.jpg"
          alt="Editorial Photography"
          title="Wedding: Anggie Editorial"
          category="wedding"
          href="/assets/foto/wedding/anggie 4 landscape.jpg"
          gallery="portfolio-gallery"
        />
      </div>

      <!-- Automotive -->
      <div class="gallery-portrait-wrap">
        <GalleryItem
          src="/assets/foto/fotografer/fotografi mobil.jpg"
          alt="Automotive Photography"
          title="Automotive: Fotografi Mobil"
          category="automotive"
          href="/assets/foto/fotografer/fotografi mobil.jpg"
          gallery="portfolio-gallery"
        />
      </div>

      <!-- Komersial -->
      <div class="gallery-portrait-wrap">
        <GalleryItem
          src="/assets/foto/fashion/foto baju coklat.jpg"
          alt="Commercial Photography"
          title="Komersial: Fashion Shoot"
          category="komersial"
          href="/assets/foto/fashion/foto baju coklat.jpg"
          gallery="portfolio-gallery"
        />
      </div>

      <!-- Lifestyle -->
      <div class="gallery-portrait-wrap">
        <GalleryItem
          src="/assets/foto/fotografer/ccm rangga.jpg"
          alt="Lifestyle Photography"
          title="Lifestyle: CCM Rangga"
          category="lifestyle"
          href="/assets/foto/fotografer/ccm rangga.jpg"
          gallery="portfolio-gallery"
        />
      </div>

      <!-- Fotografer -->
      <div class="gallery-portrait-wrap">
        <GalleryItem
          src="/assets/foto/fotografer/fotografi gojek.jpg"
          alt="Brand Photography"
          title="Fotografer: Fotografi Gojek"
          category="fotografer"
          href="/assets/foto/fotografer/fotografi gojek.jpg"
          gallery="portfolio-gallery"
        />
      </div>

    </div>
  </section>

  <PortfolioCTA />

  <Footer slot="footer" variant="minimal" />
</BaseLayout>

<script>
  /* ---------- CAROUSEL ---------- */
  (function() {
    const track = document.getElementById('carouselTrack');
    const dotsContainer = document.getElementById('carouselDots');
    if (!track) return;

    const slides = track.querySelectorAll('.carousel-slide');
    const total = slides.length;
    let current = 0;
    let autoTimer = null;

    // Build dots
    slides.forEach(function(_, i) {
      const dot = document.createElement('button');
      dot.className = 'carousel-dot' + (i === 0 ? ' active' : '');
      dot.setAttribute('aria-label', 'Slide ' + (i + 1));
      dot.addEventListener('click', function() { goTo(i); });
      dotsContainer.appendChild(dot);
    });

    function updateSlide() {
      track.style.transform = 'translateX(-' + (current * 100) + '%)';
      dotsContainer.querySelectorAll('.carousel-dot').forEach(function(d, i) {
        d.classList.toggle('active', i === current);
      });
    }

    function nextSlide() { goTo((current + 1) % total); }
    function prevSlide() { goTo((current - 1 + total) % total); }
    function goTo(index) {
      current = index;
      updateSlide();
      resetAuto();
    }
    function resetAuto() {
      clearInterval(autoTimer);
      autoTimer = setInterval(nextSlide, 4000);
    }

    // Auto-slide
    autoTimer = setInterval(nextSlide, 4000);

    // Touch — mobile swipe
    let startX = 0;
    track.addEventListener('touchstart', function(e) {
      startX = e.touches[0].clientX;
    }, { passive: true });
    track.addEventListener('touchend', function(e) {
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) diff > 0 ? nextSlide() : prevSlide();
    }, { passive: true });

    // Mouse drag — desktop
    let isDragging = false;
    track.addEventListener('mousedown', function(e) {
      startX = e.clientX;
      isDragging = true;
      e.preventDefault();
    });
    track.addEventListener('mouseup', function(e) {
      if (!isDragging) return;
      const diff = startX - e.clientX;
      if (Math.abs(diff) > 50) diff > 0 ? nextSlide() : prevSlide();
      isDragging = false;
    });
    track.addEventListener('mouseleave', function() { isDragging = false; });

    // Keyboard
    document.addEventListener('keydown', function(e) {
      if (e.key === 'ArrowRight') nextSlide();
      if (e.key === 'ArrowLeft') prevSlide();
    });

    // Pause on hover
    track.addEventListener('mouseenter', function() { clearInterval(autoTimer); });
    track.addEventListener('mouseleave', function() { autoTimer = setInterval(nextSlide, 4000); });
  })();

  /* ---------- GLIGHTBOX ---------- */
  document.addEventListener('DOMContentLoaded', function initGL() {
    if (typeof GLightbox === 'undefined') {
      setTimeout(initGL, 100);
      return;
    }
    GLightbox({
      selector: '.glightbox',
      touchNavigation: true,
      loop: true,
      autoplayVideos: false,
      zoomable: true,
    });
  });

  /* ---------- CATEGORY FILTER ---------- */
  (function() {
    const filterBar = document.querySelector('.filter-bar');
    if (!filterBar) return;
    const btns = filterBar.querySelectorAll('.filter-btn');
    const grid = document.querySelector('.gallery-grid');
    if (!grid) return;
    btns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        const filter = btn.dataset.filter;
        btns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        grid.querySelectorAll('.gallery-item').forEach(function(item) {
          const cat = item.dataset.category || '';
          item.style.display = (filter === 'all' || cat === filter) ? '' : 'none';
        });
      });
    });
  })();
</script>
